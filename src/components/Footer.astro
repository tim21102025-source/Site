---
import { ui, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang].footer;

const phones = [
  { number: '+380660575202', formatted: '+38 (066) 057-52-02', operator: 'Vodafone', class: 'vodafone-color' },
  { number: '+380989478772', formatted: '+38 (098) 947-87-72', operator: 'Kyivstar', class: 'kyivstar-color' },
  { number: '+380633664769', formatted: '+38 (063) 366-47-69', operator: 'Lifecell', class: 'lifecell-color' },
];

const prefix = lang === 'uk' ? '' : `/${lang}`;

const navLinks = [
  { key: 'home', href: prefix || '/' },
  { key: 'about', href: `${prefix}/about` },
  { key: 'vidnovlennya', href: `${prefix}/vidnovlennya` },
  { key: 'contact', href: `${prefix}/contact` },
  { key: 'conditions', href: `${prefix}/conditions` },
];

const serviceLinks = [
  { key: 'install', href: `${prefix}/service-details-install` },
  { key: 'repair', href: `${prefix}/service-details-repair` },
  { key: 'balkony', href: `${prefix}/service-details-balkony` },
  { key: 'moskitki', href: `${prefix}/service-details-moskitki` },
  { key: 'glass', href: `${prefix}/service-details-glass` },
  { key: 'dovodyachi', href: `${prefix}/service-details-dovodyachi` },
];

const usefulLinks = [
  { key: 'price', href: `${prefix}/price` },
  { key: 'doglyad', href: `${prefix}/doglyad` },
  { key: 'diagnostics', href: `${prefix}/diagnostics` },
  { key: 'aktsiya', href: `${prefix}/aktsiya` },
  { key: 'faq', href: `${prefix}/faq` },
  { key: 'blog', href: `${prefix}/blog` },
];
---

<footer id="footer" class="footer">
  <div class="footer-content position-relative">
    <div class="container">
      <div class="row gy-5">

        <!-- Logo & Contacts -->
        <div class="col-lg-4 col-md-6">
          <div class="footer-info">
            <div class="d-flex align-items-center mb-4 footer-logo-wrapper">
              <picture>
                <source srcset="/assets/img/logo.webp" type="image/webp">
                <img src="/assets/img/logo.png" alt="UWS — Сервіс вікон та дверей Київ"
                  class="img-fluid footer-logo me-3" style="max-height: 70px;" width="70" height="70">
              </picture>
              <div>
                <h3 class="fw-bold mb-1 text-warning">UWS</h3>
                <p class="text-white-75 mb-0" style="font-size: 0.85rem; line-height: 1.4;">
                  {t.description}
                </p>
              </div>
            </div>

            <div class="contact-details text-md-start">
              <strong class="d-block mb-2 text-warning">{t.phonesLabel}</strong>
              <ul class="list-unstyled mb-3">
                {phones.map(p => (
                  <li>
                    <a href={`tel:${p.number.replace(/\s/g, '')}`} class="footer-contact-item text-white text-decoration-none">
                      <i class="bi bi-telephone me-2 text-warning"></i> {p.formatted}
                      <span class={`operator-label ${p.class}`}>{p.operator}</span>
                    </a>
                  </li>
                ))}
              </ul>
              <strong class="d-block mb-2 text-warning">{t.emailLabel}</strong>
              <a href="mailto:uws.kyiv@gmail.com" class="footer-contact-item" title="Написати нам на пошту">
                <i class="bi bi-envelope me-2 text-warning"></i> uws.kyiv@gmail.com
              </a>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <div class="col-lg-2 col-md-3 offset-lg-1 text-md-start">
          <h4 class="fw-bold mb-4 text-warning">{t.navTitle}</h4>
          <ul class="list-unstyled footer-links">
            {navLinks.map(l => (
              <li class="mb-2"><a href={l.href}>{t.nav[l.key as keyof typeof t.nav]}</a></li>
            ))}
          </ul>
        </div>

        <!-- Services -->
        <div class="col-lg-3 col-md-3 text-md-start">
          <h4 class="fw-bold mb-4 text-warning">{t.servicesTitle}</h4>
          <ul class="list-unstyled footer-links">
            {serviceLinks.map(l => (
              <li class="mb-2"><a href={l.href}>{t.services[l.key as keyof typeof t.services]}</a></li>
            ))}
          </ul>
        </div>

        <!-- Useful -->
        <div class="col-lg-2 col-md-3 text-md-start">
          <h4 class="fw-bold mb-4 text-warning">{t.usefulTitle}</h4>
          <ul class="list-unstyled footer-links">
            {usefulLinks.map(l => (
              <li class="mb-2"><a href={l.href}>{t.useful[l.key as keyof typeof t.useful]}</a></li>
            ))}
          </ul>
        </div>

      </div>

      <!-- Copyright -->
      <div class="footer-legal text-center mt-4 pt-3">
        <div class="copyright small mb-1 text-white-50">
          &copy; <span id="currentYear"></span> <strong>UWS (Ukrainian Window Systems)</strong>.
          {t.copyright}
        </div>
        <div class="credits small text-white-50">
          {t.credits} <a href="https://t.me/usertim21" target="_blank"
            class="text-warning fw-bold text-decoration-none"><i class="bi bi-telegram me-1"></i>Dmitry</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('currentYear').textContent = new Date().getFullYear().toString();
</script>
