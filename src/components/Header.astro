---
import { ui, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  activePage?: string;
  headerClass?: string;
}

const { lang, activePage = 'home', headerClass = '' } = Astro.props;
const t = ui[lang];

const currentPath = Astro.url.pathname;
const cleanPath = currentPath.replace(/^\/(ru|en)(\/|$)/, '/') || '/';
const langUrls = {
  uk: cleanPath === '/' ? '/' : cleanPath,
  ru: cleanPath === '/' ? '/ru' : `/ru${cleanPath}`,
  en: cleanPath === '/' ? '/en' : `/en${cleanPath}`,
};

const phones = [
  { number: '+380660575202', formatted: '+38 (066) 057-52-02', operator: 'Vodafone', class: 'vodafone-color' },
  { number: '+380989478772', formatted: '+38 (098) 947-87-72', operator: 'Kyivstar', class: 'kyivstar-color' },
  { number: '+380633664769', formatted: '+38 (063) 366-47-69', operator: 'Lifecell', class: 'lifecell-color' },
];

const prefix = lang === 'uk' ? '' : `/${lang}`;

const services = [
  { key: 'install', href: `${prefix}/service-details-install` },
  { key: 'repair', href: `${prefix}/service-details-repair` },
  { key: 'balkony', href: `${prefix}/service-details-balkony` },
  { key: 'moskitki', href: `${prefix}/service-details-moskitki` },
  { key: 'glass', href: `${prefix}/service-details-glass` },
  { key: 'dovodyachi', href: `${prefix}/service-details-dovodyachi` },
];

const extra = [
  { key: 'aktsiya', href: `${prefix}/aktsiya` },
  { key: 'conditions', href: `${prefix}/conditions` },
  { key: 'diagnostics', href: `${prefix}/diagnostics` },
  { key: 'faq', href: `${prefix}/faq` },
  { key: 'doglyad', href: `${prefix}/doglyad` },
  { key: 'blog', href: `${prefix}/blog` },
];

const isActive = (page: string) => activePage === page ? 'active' : '';
---

<!-- Topbar -->
<div id="topbar-vidnovlennya" class="d-flex align-items-center">
  <div class="container d-flex justify-content-center justify-content-md-center">
    <a href={t.topbarLink} class="vidnovlennya-link">
      <picture>
        <source srcset="/assets/img/diia-icon.webp" type="image/webp">
        <img src="/assets/img/diia-icon.png" class="vidnovlennya-icon"
          alt="Програма єВідновлення — компенсація за пошкоджене житло" width="24" height="24">
      </picture>
      {t.topbarText}
      <span class="vidnovlennya-gradient-text" style="font-weight: 800; margin-left: 5px;">{t.topbarHighlight}</span>
    </a>
  </div>
</div>

<!-- Header -->
<header id="header" class={`header ${headerClass}`}>
  <div class="container-fluid container-xl d-flex align-items-center justify-content-between">

    <!-- Logo -->
    <a href={prefix || '/'} class="logo d-flex align-items-center">
      <picture>
        <source srcset="/assets/img/logo.webp" type="image/webp">
        <img src="/assets/img/logo.png" alt="UWS — Встановлення та ремонт вікон у Києві" class="img-fluid me-2" width="40" height="40">
      </picture>
      <span class="logo-text">UWS<span>.</span></span>
    </a>

    <!-- Mobile toggle -->
    <button class="mobile-nav-toggle mobile-nav-show" aria-label="Відкрити меню" type="button">
      <span></span><span></span><span></span>
    </button>

    <!-- Desktop Navigation -->
    <nav id="navbar" class="navbar">
      <ul>
        <li><a href={prefix || '/'} class={isActive('home')}>{t.nav.home}</a></li>
        <li><a href={`${prefix}/about`} class={isActive('about')}>{t.nav.about}</a></li>
        <li class="dropdown">
          <a href={`${prefix}/services`}><span>{t.nav.services}</span> <i class="bi bi-chevron-down dropdown-indicator"></i></a>
          <ul>
            {services.map(s => (
              <li><a href={s.href}>{t.navServices[s.key as keyof typeof t.navServices]}</a></li>
            ))}
          </ul>
        </li>
        <li><a href={`${prefix}/price`} class={isActive('price')}>{t.nav.price}</a></li>
        <li><a href={t.topbarLink} class={isActive('vidnovlennya')}>{t.nav.vidnovlennya}</a></li>
        <li class="dropdown">
          <a href="#"><span>{t.nav.extra}</span> <i class="bi bi-chevron-down dropdown-indicator"></i></a>
          <ul>
            {extra.map(e => (
              <li><a href={e.href}>{t.navExtra[e.key as keyof typeof t.navExtra]}</a></li>
            ))}
          </ul>
        </li>
        <li><a href={`${prefix}/contact`} class={isActive('contact')}>{t.nav.contact}</a></li>

        <!-- Language switcher -->
        <li class="dropdown lang-selector">
          <a href="#" class="lang-btn-style" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-globe"></i><span>{t.langSwitchLabel}</span> <i class="bi bi-chevron-down dropdown-indicator"></i>
          </a>
          <ul class="dropdown-menu">
            <li><a href={langUrls.uk}>UA</a></li>
            <li><a href={langUrls.ru}>RU</a></li>
            <li><a href={langUrls.en}>EN</a></li>
          </ul>
        </li>
      </ul>
    </nav>

    <!-- Phone button -->
    <div class="header-tools d-flex align-items-center">
      <div class="dropdown">
        <button class="btn dropdown-phone-btn d-flex align-items-center dropdown-toggle" type="button"
          data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-telephone"></i>
          <span class="d-none d-md-inline ms-2">{t.phoneBtn}</span>
          <span class="d-md-none ms-2">{t.phoneBtnMobile}</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end" style="min-width: 220px;">
          {phones.map(p => (
            <li><a class="dropdown-item d-flex align-items-center" href={`tel:${p.number.replace(/\s/g, '')}`}>
              {p.formatted} <span class={`operator-label ${p.class}`}>{p.operator}</span>
            </a></li>
          ))}
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item d-flex align-items-center" href={activePage === 'home' ? '#get-started' : `${prefix}/contact`}>
            <i class="bi bi-pencil-square me-2"></i> {t.requestBtn}
          </a></li>
        </ul>
      </div>
    </div>

  </div>
</header>

<!-- Mobile Navigation Overlay + Panel (outside header for proper z-index) -->
<div id="mobile-overlay" class="mobile-overlay"></div>
<nav id="mobile-nav" class="mobile-nav">
  <div class="mobile-nav-header">
    <a href={prefix || '/'} class="mobile-nav-logo d-flex align-items-center">
      <picture>
        <source srcset="/assets/img/logo.webp" type="image/webp">
        <img src="/assets/img/logo.png" alt="UWS" width="32" height="32">
      </picture>
      <span class="logo-text">UWS<span>.</span></span>
    </a>
    <button class="mobile-nav-close" aria-label="Закрити меню" type="button">
      <i class="bi bi-x-lg"></i>
    </button>
  </div>
  <div class="mobile-nav-body">
    <ul>
      <li><a href={prefix || '/'} class={isActive('home')}>{t.nav.home}</a></li>
      <li><a href={`${prefix}/about`} class={isActive('about')}>{t.nav.about}</a></li>
      <li class="dropdown">
        <a href={`${prefix}/services`} class="dropdown-toggle-mobile"><span>{t.nav.services}</span> <i class="bi bi-chevron-down dropdown-indicator"></i></a>
        <ul class="dropdown-mobile">
          {services.map(s => (
            <li><a href={s.href}>{t.navServices[s.key as keyof typeof t.navServices]}</a></li>
          ))}
        </ul>
      </li>
      <li><a href={`${prefix}/price`} class={isActive('price')}>{t.nav.price}</a></li>
      <li><a href={t.topbarLink} class={isActive('vidnovlennya')}>{t.nav.vidnovlennya}</a></li>
      <li class="dropdown">
        <a href="#" class="dropdown-toggle-mobile"><span>{t.nav.extra}</span> <i class="bi bi-chevron-down dropdown-indicator"></i></a>
        <ul class="dropdown-mobile">
          {extra.map(e => (
            <li><a href={e.href}>{t.navExtra[e.key as keyof typeof t.navExtra]}</a></li>
          ))}
        </ul>
      </li>
      <li><a href={`${prefix}/contact`} class={isActive('contact')}>{t.nav.contact}</a></li>
    </ul>
  </div>
  <div class="mobile-nav-footer">
    <div class="mobile-nav-phones">
      {phones.map(p => (
        <a href={`tel:${p.number.replace(/\s/g, '')}`} class="mobile-nav-phone-item">
          <i class={`bi bi-telephone-fill ${p.class}`}></i>
          <span>{p.formatted}</span>
          <span class={`operator-label ${p.class}`}>{p.operator}</span>
        </a>
      ))}
    </div>
    <a href="mailto:uws.kyiv@gmail.com" class="mobile-nav-email">
      <i class="bi bi-envelope-fill"></i> uws.kyiv@gmail.com
    </a>
    <div class="mobile-nav-msg-section">
      <span class="mobile-nav-msg-label">{lang === 'en' ? 'Write to us' : (lang === 'uk' ? 'Написати нам' : 'Написать нам')}</span>
      <div class="mobile-nav-msg-row">
        <a href="viber://chat?number=%2B380730705280" class="msg-pill msg-viber">
          <i class="bi bi-chat-dots-fill"></i> Viber
        </a>
        <a href="https://t.me/+380730705280" target="_blank" rel="noopener" class="msg-pill msg-tg">
          <i class="bi bi-send-fill"></i> Telegram
        </a>
        <a href="https://wa.me/380730705280" target="_blank" rel="noopener" class="msg-pill msg-wa">
          <i class="bi bi-whatsapp"></i> WhatsApp
        </a>
      </div>
    </div>
    <a href={activePage === 'home' ? '#get-started' : `${prefix}/contact`} class="mobile-nav-cta">
      {t.requestBtn}
    </a>
    <div class="mobile-nav-lang">
      <a href={langUrls.uk}>UA</a>
      <span class="mx-1">|</span>
      <a href={langUrls.ru}>RU</a>
      <span class="mx-1">|</span>
      <a href={langUrls.en}>EN</a>
    </div>
  </div>
</nav>
