---
import { readFileSync } from 'fs';
import { join } from 'path';

const content = readFileSync(join(process.cwd(), 'public', 'llms-full.txt'), 'utf-8');
---
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="utf-8">
  <title>llms-full.txt — UWS</title>
  <meta name="robots" content="noindex">
  <style>body{font-family:monospace;max-width:900px;margin:2rem auto;padding:0 1rem;line-height:1.6;white-space:pre-wrap}</style>
</head>
<body set:html={content} />
</html>
