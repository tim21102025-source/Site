---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import { getServiceStructuredData } from '../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Встановлення та Ремонт Вікон Київ',
  description: 'Професійне встановлення металопластикових вікон, дверей та балконів. Ремонт, регулювання, обслуговування у Києві та області. Гарантія до 5 років.',
  url: 'https://uws.com.ua/',
});
---

<BaseLayout
  lang="uk"
  title="UWS — Встановлення та Ремонт Вікон Київ | Регулювання Пластикових Вікон"
  description="Встановлення металопластикових вікон, дверей, балконів у Києві. Ремонт, регулювання, заміна фурнітури, ущільнювача, склопакетів. Гарантія до 5 років, безкоштовний виїзд майстра."
  canonicalPath="/"
  structuredData={structuredData}
  preloadImage="/assets/img/hero-carousel/hero-carousel-1.webp"
>
  <Header lang="uk" activePage="home" />

  <section id="hero" class="hero">
    <div class="info d-flex align-items-center">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-6 text-center">
            <h1 data-aos="fade-down">Встановлення та Ремонт Вікон Київ</h1>
            <h2 data-aos="fade-up">Регулювання пластикових вікон · Заміна фурнітури · Гарантія до 5 років · Безкоштовний виїзд</h2>
            <p data-aos="fade-up">Професійне встановлення металопластикових вікон, дверей, балконів. Ремонт, усунення протягів, заміна ущільнювача та склопакетів у Києві та області.</p>
            <a data-aos="fade-up" data-aos-delay="200" href="#get-started" class="btn-get-started">Викликати майстра</a>
          </div>
        </div>
      </div>
    </div>
    <div id="hero-carousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
      <div class="carousel-item active" style="background-image: url(/assets/img/hero-carousel/hero-carousel-1.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-2.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-3.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-4.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-5.webp)"></div>
      <a class="carousel-control-prev" href="#hero-carousel" role="button" data-bs-slide="prev">
        <span class="carousel-control-prev-icon bi bi-chevron-left" aria-hidden="true"></span>
      </a>
      <a class="carousel-control-next" href="#hero-carousel" role="button" data-bs-slide="next">
        <span class="carousel-control-next-icon bi bi-chevron-right" aria-hidden="true"></span>
      </a>
    </div>
  </section>

  <main id="main">
    <section class="get-started py-5">
      <div class="container">
        <div class="row justify-content-between gy-4">
          <div class="col-lg-6 d-flex align-items-center" data-aos="fade-up">
            <div class="content ps-lg-4">
              <h2 class="fw-bold mb-4" style="color: #1a252b;">Чому обирають нас для ремонту та регулювання пластикових вікон у Києві</h2>
              <p class="mb-4 text-secondary" style="font-size: 1rem;">Не чекайте, поки з вікна почне дути або зламається ручка. Ми повертаємо тепло, тишу та безпеку у вашу оселю за один візит, заощаджуючи до 40% на витратах за опалення.</p>
              <div class="features-mini mb-4">
                <div class="d-flex align-items-start mb-3">
                  <div class="icon-box bg-warning-light p-2 rounded-3 me-3"><i class="bi bi-patch-check-fill text-warning fs-4"></i></div>
                  <div>
                    <strong class="fw-bold d-block mb-1">Безкоштовний виїзд та діагностика</strong>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">При укладанні договору майстер проведе повний технічний огляд усіх вікон безкоштовно.</p>
                  </div>
                </div>
                <div class="d-flex align-items-start mb-3">
                  <div class="icon-box bg-warning-light p-2 rounded-3 me-3"><i class="bi bi-camera-fill text-warning fs-4"></i></div>
                  <div>
                    <strong class="fw-bold d-block mb-1">Миттєвий розрахунок вартості</strong>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Надішліть фото або відео проблеми — наш експерт оцінить вартість ремонту за 5 хвилин.</p>
                  </div>
                </div>
                <div class="d-flex align-items-start mb-3">
                  <div class="icon-box bg-warning-light p-2 rounded-3 me-3"><i class="bi bi-shield-lock-fill text-warning fs-4"></i></div>
                  <div>
                    <strong class="fw-bold d-block mb-1">Гарантія 12 місяців + офіційний договір</strong>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Використовуємо лише оригінальні комплектуючі (Німеччина, Австрія) та надаємо офіційний чек.</p>
                  </div>
                </div>
              </div>
              <div class="p-3 rounded-4 bg-white shadow-sm border-start border-warning border-5 mb-4">
                <strong class="fw-bold d-block mb-2" style="font-size: 0.95rem;">Отримайте консультацію прямо зараз:</strong>
                <p class="text-muted mb-3" style="font-size: 0.8rem;">Наші майстри онлайн у зручному месенджері:</p>
                <div class="d-flex flex-wrap gap-2 messenger-buttons-group">
                  <a href="viber://chat?number=%2B380730705280" class="btn text-white px-4 py-2 d-flex align-items-center justify-content-center messenger-btn viber-bg"><i class="bi bi-chat-dots-fill me-2"></i> Viber</a>
                  <a href="https://t.me/+380730705280" class="btn text-white px-4 py-2 d-flex align-items-center justify-content-center messenger-btn telegram-bg"><i class="bi bi-telegram me-2"></i> Telegram</a>
                  <a href="https://wa.me/380730705280" class="btn text-white px-4 py-2 d-flex align-items-center justify-content-center messenger-btn whatsapp-bg"><i class="bi bi-whatsapp me-2"></i> WhatsApp</a>
                </div>
              </div>
            </div>
          </div>
          <div id="get-started" class="col-lg-5" data-aos="fade">
            <form action="" method="post" class="php-email-form telegram-form shadow-lg p-4 p-md-5 rounded-4 bg-white">
              <h3 class="fs-4 fw-bold mb-2">Швидка заявка на ремонт вікон у Києві</h3>
              <p class="text-muted small mb-4">Залиште контакти — майстер зателефонує протягом 15 хвилин</p>
              <div class="row gy-3">
                <div class="col-md-12 form-group">
                  <input type="text" name="name" class="form-control" placeholder="Ваше Ім'я" required style="border-radius: 8px; padding: 12px;">
                </div>
                <div class="col-md-12 form-group">
                  <div class="input-group">
                    <span class="input-group-text" style="background: #f8f9fa; border-radius: 8px 0 0 8px;">+38</span>
                    <input type="tel" class="form-control" name="phone" placeholder="066 057 52 02" pattern="^(\\s*\\d){10}\\s*$" required style="border-radius: 0 8px 8px 0; padding: 12px;">
                  </div>
                </div>
                <div class="col-md-12 form-group">
                  <textarea class="form-control" name="message" rows="3" placeholder="Опишіть, що сталося" required style="border-radius: 8px; padding: 12px;"></textarea>
                </div>
                <div class="form-group mb-3">
                  <div class="d-flex align-items-center mb-2">
                    <label class="form-label small fw-bold mb-0">Фото або відео проблеми</label>
                    <span class="ms-2 small opacity-50" style="font-size: 0.75rem;">(можна обрати кілька)</span>
                  </div>
                  <input type="file" id="files" class="d-none" accept="image/*,video/*" multiple>
                  <button type="button" class="btn btn-outline-secondary w-100 py-2 d-flex align-items-center justify-content-center" onclick="document.getElementById('files').click()" style="border-style: dashed;">
                    <i class="bi bi-camera me-2 fs-5"></i>
                    <span>Додати медіафайли</span>
                  </button>
                  <div id="file-preview" class="d-flex flex-wrap gap-2 mt-2"></div>
                </div>
                <div class="col-md-12 text-center">
                  <input type="text" name="hp_field" style="display:none !important" tabindex="-1" autocomplete="off">
                  <button type="submit" class="w-100 py-3 fw-bold text-dark border-0 shadow-sm btn-animate" style="background: #feb900; border-radius: 8px;">Отримати безкоштовну консультацію</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Секція послуг -->
    <section id="services" class="services section-bg">
      <div class="container" data-aos="fade-up">
        <div class="section-header">
          <h2 class="fw-bold">Повний спектр послуг з встановлення та ремонту вікон у Києві</h2>
          <p>Від термінового ремонту та регулювання до комплексного скління балконів — професійний підхід до кожного вікна</p>
        </div>

        <div class="row gy-4">
          <!-- Картка 1 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/install.webp" type="image/webp">
                  <img src="/assets/img/services/install.jpg" class="img-fluid w-100" alt="Встановлення металопластикових вікон та дверей Київ" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-window-plus"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Встановлення вікон та дверей</h3>
                <p class="text-muted small">Монтаж енергоефективних систем за стандартами ДСТУ. Гарантія теплоізоляції та довговічності.</p>
                <hr class="my-3 opacity-10">
                <a href="/service-details-install" class="stretched-link text-warning fw-bold text-decoration-none">Детальніше <i class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <!-- Картка 2 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/repair.webp" type="image/webp">
                  <img src="/assets/img/services/repair.jpg" class="img-fluid w-100" alt="Ремонт та регулювання пластикових вікон Київ" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-tools"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Ремонт вікон та дверей</h3>
                <p class="text-muted small">Усунення протягів, заміна фурнітури та регулювання. Повертаємо функціональність за один візит.</p>
                <hr class="my-3 opacity-10">
                <a href="/service-details-repair" class="stretched-link text-warning fw-bold text-decoration-none">Детальніше <i class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <!-- Картка 3 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/balkony.webp" type="image/webp">
                  <img src="/assets/img/services/balkony.jpg" class="img-fluid w-100" alt="Скління та утеплення балконів та лоджій Київ" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-house-door"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Балкони та лоджії</h3>
                <p class="text-muted small">Комплексне скління, утеплення та внутрішня обробка. Перетворюємо балкон на затишну кімнату.</p>
                <hr class="my-3 opacity-10">
                <a href="/service-details-balkony" class="stretched-link text-warning fw-bold text-decoration-none">Детальніше <i class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <!-- Картка 4 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/glass.webp" type="image/webp">
                  <img src="/assets/img/services/glass.jpg" class="img-fluid w-100" alt="Заміна склопакетів у вікнах Київ" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-aspect-ratio"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Заміна склопакетів</h3>
                <p class="text-muted small">Заміна розбитих або енергозберігаючих пакетів. Покращення шумоізоляції та енергоефективності.</p>
                <hr class="my-3 opacity-10">
                <a href="/service-details-glass" class="stretched-link text-warning fw-bold text-decoration-none">Детальніше <i class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <!-- Картка 5 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/moskitki.webp" type="image/webp">
                  <img src="/assets/img/services/moskitki.jpg" class="img-fluid w-100" alt="Виготовлення та встановлення москітних сіток Київ" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-shield-check"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Москітні сітки</h3>
                <p class="text-muted small">Всі види сіток: рамкові, ролетні, "Антикішка". Виготовлення за вашими розмірами за 1-2 дні.</p>
                <hr class="my-3 opacity-10">
                <a href="/service-details-moskitki" class="stretched-link text-warning fw-bold text-decoration-none">Детальніше <i class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <!-- Картка 6 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/dovodyachi.webp" type="image/webp">
                  <img src="/assets/img/services/dovodyachi.jpg" class="img-fluid w-100" alt="Встановлення доводчиків на двері Київ" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-door-closed"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Доводчики для дверей</h3>
                <p class="text-muted small">Професійний підбір та монтаж доводчиків на пластикові та металеві двері. Плавність ходу гарантована.</p>
                <hr class="my-3 opacity-10">
                <a href="/service-details-dovodyachi" class="stretched-link text-warning fw-bold text-decoration-none">Детальніше <i class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>
        </div>

        <!-- Блок єВідновлення -->
        <div class="mt-5 p-4 rounded-4 shadow-sm bg-white border-start border-warning border-4 d-flex align-items-center justify-content-between flex-wrap gap-3" data-aos="fade-up">
          <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-patch-check text-warning me-2"></i> Працюємо за програмою єВідновлення</h4>
            <p class="mb-0 text-muted">Надаємо офіційні документи та приймаємо оплату карткою для відновлення вашого житла.</p>
          </div>
          <a href="/vidnovlennya" class="btn btn-warning fw-bold px-4">Дізнатись більше</a>
        </div>
      </div>
    </section>

    <!-- Секція: 5 причин, чому обирають UWS -->
    <section id="alt-services" class="alt-services">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-around gy-4">
          <div class="col-lg-6 img-bg" style="background-image: url(/assets/img/alt-services.jpg); border-radius: 20px; box-shadow: 0 15px 30px rgba(0,0,0,0.1);" data-aos="zoom-in" data-aos-delay="100"></div>
          <div class="col-lg-5 d-flex flex-column justify-content-center">
            <h2 class="fw-bold mb-3">5 причин довірити встановлення та ремонт вікон саме UWS</h2>
            <p class="text-muted mb-4">Ми поєднуємо 10+ років досвіду та сучасні стандарти сервісу, щоб ваші вікна служили десятиліттями:</p>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="100">
              <i class="bi bi-award flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">10+ років досвіду</a></strong>
                <p>Знаємо всі тонкощі роботи з будь-якими профільними системами: від класичних до елітних.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="200">
              <i class="bi bi-shield-check flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">Офіційна гарантія</a></strong>
                <p>Надаємо гарантійний сертифікат на виконані роботи та встановлені запчастини.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="300">
              <i class="bi bi-gear-wide-connected flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">Європейські комплектуючі</a></strong>
                <p>Жодних дешевих аналогів — використовуємо тільки оригінальну фурнітуру (Maco, Roto, Siegenia).</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="400">
              <i class="bi bi-lightning-charge flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">Оперативність</a></strong>
                <p>Власний склад запчастин дозволяє виконувати 90% ремонтів прямо під час першого візиту.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="500">
              <i class="bi bi-cash-coin flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">Чесна вартість</a></strong>
                <p>Фіксуємо ціну в кошторисі до початку робіт. Ви точно знаєте, за що платите.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Секція: Яку проблему з вікнами вирішити? -->
    <section id="features" class="features section-bg">
      <div class="container" data-aos="fade-up">
        <div class="section-header text-center">
          <h2 class="fw-bold">Яку проблему з вікнами вирішити? — Ремонт та регулювання у Києві</h2>
          <p>Оберіть свою ситуацію — ми покажемо швидке та професійне рішення</p>
        </div>

        <ul class="nav nav-tabs row g-2 d-flex border-0 mb-4">
