---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import { getServiceStructuredData } from '../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Ремонт Вікон за Програмою єВідновлення Київ',
  description: 'Офіційний учасник програми єВідновлення. Ремонт та заміна вікон за державну компенсацію у Києві. Гарантія до 5 років.',
  url: 'https://uws.com.ua/vidnovlennya',
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="vidnovlennya-intro" class="about py-5">
      <div class="container" data-aos="fade-up">

        <!-- Головний H1 + вступ -->
        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">єВідновлення — Ремонт та Заміна Вікон за Державною Компенсацією</h1>
          <p class="lead text-muted mt-3">UWS — офіційний учасник програми з травня 2023 року. Повний супровід,
            безкоштовний замір та гарантія на роботи.</p>
        </header>

        <div class="row position-relative gy-5">
          <div class="col-lg-5 about-img mt-3 mb-0 shadow-sm"
            style="background-image: url('/assets/img/vidnovlennya.png'); min-height: 400px; background-size: cover; background-position: center;">
          </div>

          <div class="col-lg-7">
            <h2 class="h3 fw-bold mb-4">Відновіть своє житло з компенсацією від держави</h2>

            <p class="lead fw-bold mb-4">
              Ваші вікна будуть як нові! UWS — офіційний партнер програми «єВідновлення».
            </p>

            <p class="mb-4">
              Якщо ваше житло постраждало, ви можете використати державну компенсацію на ремонт або повну заміну
              пошкоджених вікон та дверей. Ми беремо на себе весь процес — від заміру до встановлення та звітності.
            </p>

            <h3 class="h4 fw-bold mb-3 d-flex align-items-center">
              <i class="bi bi-tools text-warning me-2"></i> Роботи, що компенсуються:
            </h3>

            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Заміна склопакетів:</strong> Повна заміна розбитих або пошкоджених пакетів будь-якого типу.
                </div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Ремонт фурнітури:</strong> Заміна ручок, механізмів, ущільнювачів.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Встановлення нових конструкцій:</strong> Демонтаж старих та монтаж нових вікон і дверей.
                </div>
              </li>
            </ul>

            <p class="fst-italic mt-4">
              <i class="bi bi-info-circle-fill text-warning me-1"></i>
              Наші менеджери допоможуть обрати рішення під вашу суму компенсації та підготують усі документи.
            </p>

            <a href="/contact"
              class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold mt-3 d-inline-flex align-items-center shadow">
              <i class="bi bi-arrow-right-circle me-2"></i> Залишити заявку на консультацію
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="features section-bg py-5">
      <div class="container" data-aos="fade-up">

        <header class="text-center mb-5">
          <h2 class="fw-bold">Переваги роботи з UWS за програмою єВідновлення</h2>
          <p class="text-muted">Ми гарантуємо швидкий, прозорий та якісний процес відновлення.</p>
        </header>

        <div class="row feature-icons gy-5">
          <div class="col-xl-4 text-center" data-aos="fade-right" data-aos-delay="100">
            <div class="icon-box h-100 p-4 shadow-sm rounded-4 bg-white">
              <i class="bi bi-patch-check text-warning" style="font-size: 48px; margin-bottom: 15px;"></i>
              <h3 class="h5 fw-bold">Офіційний учасник</h3>
              <p>Зареєстровані в програмі з травня 2023 року. Усі документи відповідають державним вимогам.</p>
            </div>
          </div>
          <div class="col-xl-4 text-center" data-aos="fade-up" data-aos-delay="200">
            <div class="icon-box h-100 p-4 shadow-sm rounded-4 bg-white">
              <i class="bi bi-speedometer text-warning" style="font-size: 48px; margin-bottom: 15px;"></i>
              <h3 class="h5 fw-bold">Швидкість та Оперативність</h3>
              <p>Виїзд майстра в день звернення, швидке виготовлення та монтаж після отримання коштів.</p>
            </div>
          </div>
          <div class="col-xl-4 text-center" data-aos="fade-left" data-aos-delay="300">
            <div class="icon-box h-100 p-4 shadow-sm rounded-4 bg-white">
              <i class="bi bi-award text-warning" style="font-size: 48px; margin-bottom: 15px;"></i>
              <h3 class="h5 fw-bold">Гарантія Якості</h3>
              <p>Якісні матеріали, професійний монтаж та офіційна гарантія до 5 років.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="alt-services" class="alt-services py-5">
      <div class="container" data-aos="fade-up">

        <header class="text-center mb-5">
          <h2 class="fw-bold">Покрокова інструкція отримання компенсації та замовлення</h2>
        </header>

        <!-- Частина 1 -->
        <div class="row justify-content-around gy-5 alt-services-item" data-aos="fade-up" data-aos-delay="100">

          <div class="col-lg-5 d-flex flex-column justify-content-center">
            <h3 class="h4 fw-bold mb-4">Частина 1: Отримання коштів на карту</h3>

            <div class="icon-box d-flex position-relative mb-4" data-aos="fade-up" data-aos-delay="100">
              <i class="bi bi-1-circle flex-shrink-0 text-warning fs-3"></i>
              <div class="ms-4">
                <h4 class="fw-bold">Крок 1. Подайте заяву</h4>
                <p class="text-muted mb-0">Через додаток або портал «Дія».</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative mb-4" data-aos="fade-up" data-aos-delay="200">
              <i class="bi bi-2-circle flex-shrink-0 text-warning fs-3"></i>
              <div class="ms-4">
                <h4 class="fw-bold">Крок 2. Відкрийте рахунок</h4>
                <p class="text-muted mb-0">Спеціальний рахунок єВідновлення в банку-партнері.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="300">
              <i class="bi bi-3-circle flex-shrink-0 text-warning fs-3"></i>
              <div class="ms-4">
                <h4 class="fw-bold">Крок 3. Дочекайтеся схвалення</h4>
                <p class="text-muted mb-0">Комісія огляне пошкодження та зарахує кошти на вашу карту.</p>
              </div>
            </div>
          </div>
          <div class="col-lg-6"
            style="background-image: url('/assets/img/vidnovlennya-1.png'); min-height: 120px; background-size: cover; background-position: center;">
          </div>
        </div>

        <!-- Частина 2 -->
        <div class="row justify-content-around alt-services-item flex-row-reverse flex-lg-row mt-5" data-aos="fade-up"
          data-aos-delay="100">
          <div class="col-lg-6"
            style="background-image: url('/assets/img/vidnovlennya-2.png'); min-height: 120px; background-size: cover; background-position: center;">
          </div>
          <div class="col-lg-5 d-flex flex-column justify-content-center">
            <h3 class="h4 fw-bold mb-4">Частина 2: Замовлення у UWS</h3>

            <div class="icon-box d-flex position-relative mb-4" data-aos="fade-up" data-aos-delay="100">
              <i class="bi bi-4-circle flex-shrink-0 text-warning fs-3"></i>
              <div class="ms-4">
                <h4 class="fw-bold">Крок 4. Зв'яжіться з нами</h4>
                <p class="text-muted mb-0">Ми складемо кошторис, що відповідає сумі вашої компенсації.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative mb-4" data-aos="fade-up" data-aos-delay="200">
              <i class="bi bi-5-circle flex-shrink-0 text-warning fs-3"></i>
              <div class="ms-4">
                <h4 class="fw-bold">Крок 5. Оплатіть замовлення</h4>
                <p class="text-muted mb-0">Карткою єВідновлення — ми одразу запускаємо виготовлення.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="300">
              <i class="bi bi-6-circle flex-shrink-0 text-warning fs-3"></i>
              <div class="ms-4">
                <h4 class="fw-bold">Крок 6. Отримайте нові вікна</h4>
                <p class="text-muted mb-0">Професійний монтаж та офіційна гарантія UWS.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>


    <section class="contact py-5" data-aos="fade-up">
      <div class="container">
        <div class="p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
          style="background: linear-gradient(135deg, #2a3d47 0%, #1a252b 100%); border: 1px solid rgba(254, 185, 0, 0.3);">

          <div class="position-relative">
            <div class="mb-4">
              <i class="bi bi-bank2 text-warning" style="font-size: 3rem;"></i>
            </div>

            <h3 class="text-white mb-3" style="font-weight: 700; font-size: 2rem;">
              Готові розпочати відновлення оселі?
            </h3>

            <div class="row justify-content-center mb-4">
              <div class="col-lg-8">
                <p class="text-white-50" style="font-size: 1.1rem;">
                  Ми є офіційним партнером програми <span class="text-white">єВідновлення</span>. Надаємо повний пакет
                  документів та приймаємо оплату безпосередньо карткою компенсації.
                </p>
              </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
              <a href="/contact"
                class="btn btn-warning px-5 py-3 fw-bold shadow text-dark d-inline-flex align-items-center">
                <i class="bi bi-clipboard2-check me-2"></i> Замовити дефектний акт та замір
              </a>
              <a href="tel:+380660575202"
                class="btn btn-outline-light px-5 py-3 fw-bold d-inline-flex align-items-center">
                <i class="bi bi-info-circle text-warning me-2"></i> Допомога з оформленням
              </a>
            </div>

            <div class="mt-4 d-flex align-items-center justify-content-center flex-wrap gap-4 text-white-50 small">
              <div class="d-flex align-items-center"><i class="bi bi-file-earmark-text me-2 text-warning"></i> Офіційний
                договір</div>
              <div class="d-flex align-items-center"><i class="bi bi-credit-card-2-back me-2 text-warning"></i> Оплата
                єВідновлення</div>
              <div class="d-flex align-items-center"><i class="bi bi-shield-check me-2 text-warning"></i> Повна
                звітність</div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"єВідновлення Київ 2026 | Ремонт та Заміна Вікон за Компенсацією — UWS"}
  description={"Офіційний учасник програми єВідновлення у Києві. Ремонт, заміна вікон та дверей за державні кошти. Безкоштовний замір, повний супровід. Гарантія до 5 років."}
  canonicalPath={"/vidnovlennya"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="vidnovlennya" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
