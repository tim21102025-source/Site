---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "UWS — Встановлення, Ремонт Вікон та Дверей Київ",
  "image": "https://uws.com.ua/assets/img/logo.png",
  "telephone": [
    "+380660575202",
    "+380989478772",
    "+380633664769"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Київ",
    "addressCountry": "UA"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "09:00",
    "closes": "20:00"
  },
  "description": "Актуальні акції та знижки на ремонт, регулювання, встановлення металопластикових вікон, дверей, балконів у Києві. Учасник програми єВідновлення.",
  "url": "https://uws.com.ua/aktsiya.html",
  "priceRange": "$$",
  "offers": {
    "@type": "Offer",
    "itemOffered": {
      "@type": "Service",
      "name": "Комплексне обслуговування вікон «Зимовий комфорт»"
    },
    "priceCurrency": "UAH",
    "price": "0",
    "availability": "https://schema.org/InStock",
    "validFrom": "2026-01-01",
    "validThrough": "2026-01-31"
  }
};

const mainHtml = `<div class="page-header-mini d-flex align-items-center" style="background-image: url('/assets/img/breadcrumbs-bg.jpg');">
      <div class="container position-relative"></div>
    </div>



    <!-- Головна акційна пропозиція (H1 тут!) -->
    <section id="hero-offer" class="py-5">
      <div class="container" data-aos="fade-up">
        <div class="row g-0 shadow-lg rounded-4 overflow-hidden bg-white">
          <div class="col-lg-6 position-relative">
            <div class="about-img h-100"
              style="background-image: url(/assets/img/aktsiya-1.jpg'); min-height: 420px; background-size: cover; background-position: center;">
            </div>
            <div class="position-absolute top-0 start-0 m-4">
              <span class="badge bg-danger fs-5 px-4 py-2">Зима 2026</span>
            </div>
          </div>
          <div class="col-lg-6 p-4 p-lg-5 d-flex flex-column justify-content-center">
            <h1 class="fw-bold display-5 mb-4">Комплекс «Зимовий комфорт» — -20% на все!</h1>
            <p class="lead text-primary fw-bold fs-4 mb-4">Повне обслуговування всіх вікон квартири за спеціальною ціною
            </p>

            <p class="mb-4">Регулювання + змащування фурнітури + заміна ущільнювача + діагностика — усе в одному
              замовленні зі знижкою 20%. Ідеальний варіант перед сильними морозами!</p>

            <div class="d-flex align-items-center mb-4">
              <i class="bi bi-exclamation-triangle-fill text-danger me-3 fs-3"></i>
              <span class="fw-bold text-uppercase">Акція діє до 28 лютого 2026 року</span>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3">
              <a href="tel:+380660575202" class="btn btn-warning btn-lg fw-bold px-5 py-3 shadow">
                <i class="bi bi-telephone-fill me-2"></i> Забронювати знижку
              </a>
              <a href="/contact#contact" class="btn btn-outline-primary btn-lg fw-bold px-5 py-3">
                Отримати розрахунок
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Додаткові вигідні пропозиції -->
    <section id="more-promotions" class="section-bg py-5">
      <div class="container" data-aos="fade-up">
        <div class="section-header text-center pb-5">
          <h2>Інші вигідні пропозиції UWS у 2026 році</h2>
          <p class="lead">Оберіть свою знижку та заощаджуйте на якісному ремонті та встановленні вікон</p>
        </div>

        <div class="row gy-4">
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 border-0 shadow-sm promo-card">
              <div class="card-body p-4 text-center">
                <div class="icon-circle mb-4 mx-auto"
                  style="width:80px;height:80px;background:#e3f2fd;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                  <i class="bi bi-people-fill text-primary" style="font-size:2.5rem;"></i>
                </div>
                <h3 class="h4 fw-bold mb-3">Соціальна турбота</h3>
                <p class="mb-3">Знижка <strong class="text-primary fs-4">10–15%</strong> для:</p>
                <ul class="list-unstyled text-start mb-4">
                  <li><i class="bi bi-check-circle-fill text-success me-2"></i>Пенсіонерів</li>
                  <li><i class="bi bi-check-circle-fill text-success me-2"></i>Багатодітних сімей</li>
                  <li><i class="bi bi-check-circle-fill text-success me-2"></i>Військовослужбовців ЗСУ</li>
                </ul>
                <small class="text-muted">* за наявності посвідчення</small>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 border-0 shadow-sm promo-card">
              <div class="card-body p-4 text-center">
                <div class="icon-circle mb-4 mx-auto"
                  style="width:80px;height:80px;background:#fff3cd;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                  <i class="bi bi-gift-fill text-warning" style="font-size:2.5rem;"></i>
                </div>
                <h3 class="h4 fw-bold mb-3">Сітки в подарунок</h3>
                <p class="mb-4">Замовлення встановлення <strong>3+ вікон</strong> «під ключ» → москітні сітки на всі
                  вікна <strong>безкоштовно</strong>!</p>
                <div class="badge bg-success fs-5 px-4 py-2">Економія до 1800 грн</div>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 border-0 shadow-sm promo-card">
              <div class="card-body p-4 text-center">
                <div class="icon-circle mb-4 mx-auto"
                  style="width:80px;height:80px;background:#d1e7dd;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                  <i class="bi bi-house-heart-fill text-success" style="font-size:2.5rem;"></i>
                </div>
                <h3 class="h4 fw-bold mb-3">Підтримка ВПО</h3>
                <p class="mb-3">Спеціальні умови та додаткові знижки на ремонт/заміну пошкоджених вікон для внутрішньо
                  переміщених осіб</p>
                <div class="text-primary fw-bold">Разом до перемоги та відновлення!</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Потужний CTA блок -->
    <section class="py-5 bg-dark text-white text-center">
      <div class="container" data-aos="zoom-in">
        <div class="row justify-content-center">
          <div class="col-lg-9 col-xl-8">
            <h2 class="display-5 fw-bold mb-4" style="color: var(--color-primary);">Акції розлітаються швидко!</h2>
            <p class="fs-4 mb-5 opacity-85">
              Майстри вже завантажені на 70% у січні. Забронюйте своє вікно за акційною ціною <strong>прямо
                зараз</strong> — кількість місць обмежена!
            </p>

            <div class="d-flex flex-column flex-md-row justify-content-center gap-4 mb-5">
              <a href="tel:+380660575202" class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg">
                <i class="bi bi-telephone-fill me-2"></i> ЗАФІКСОВАТИ ЗНИЖКУ
              </a>
              <a href="/contact#contact" class="btn btn-outline-light btn-lg px-5 py-3 rounded-pill">
                <i class="bi bi-envelope me-2"></i> Отримати персональну пропозицію
              </a>
            </div>

            <div class="d-flex flex-wrap justify-content-center gap-4 opacity-75 small">
              <div><i class="bi bi-shield-check-fill me-2"></i>Гарантія до 5 років</div>
              <div><i class="bi bi-truck me-2"></i>Безкоштовний виїзд</div>
              <div><i class="bi bi-clock-history me-2"></i>Фіксація ціна по телефону</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Фінальний блок "Індивідуально" -->
    <section class="py-5">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-center align-items-center gy-5">
          <div class="col-lg-6">
            <div class="img-bg rounded-4 shadow-lg"
              style="background-image: url(/assets/img/aktsiya-2.jpg'); min-height: 380px; background-size: cover; background-position: center;">
            </div>
          </div>
          <div class="col-lg-6">
            <h3 class="fw-bold display-6 mb-4">Потрібен великий об'єм або складний об'єкт?</h3>
            <p class="lead mb-4">ОСББ, школи, садочки, офіси, багатоквартирні будинки — працюємо з великими обсягами та
              пропонуємо індивідуальні умови.</p>

            <div class="icon-box d-flex mb-4">
              <i class="bi bi-patch-check-fill text-primary fs-2 flex-shrink-0 me-3"></i>
              <div>
                <h4 class="fw-bold">Персональна ціна</h4>
                <p class="mb-0">Обговоримо найкращі умови саме для вашого об'єкта</p>
              </div>
            </div>

            <div class="icon-box d-flex">
              <i class="bi bi-calendar-check-fill text-primary fs-2 flex-shrink-0 me-3"></i>
              <div>
                <h4 class="fw-bold">Бронювання комплектуючих</h4>
                <p class="mb-0">Замовимо матеріали по акційній ціні вже сьогодні</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"Акції та знижки на ремонт і встановлення вікон у Києві 2026 | UWS"}
  description={"Актуальні акції UWS у січні 2026: -20% на комплексне обслуговування вікон, знижки для пенсіонерів, ВПО та ЗСУ, безкоштовні москітні сітки, спеціальні умови по програмі єВідновлення в Києві та області."}
  canonicalPath={"/aktsiya"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="aktsiya" />

  <Fragment set:html={mainHtml} />

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
