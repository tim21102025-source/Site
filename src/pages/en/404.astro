---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  lang="en"
  title="404 — Page Not Found | UWS"
  description="Page not found. Return to the homepage or contact us."
  canonicalPath="/en/404"
>
  <Header lang="en" activePage="home" headerClass="header-solid" />

  <main id="main" class="mt-5">
    <section class="section-bg" style="min-height: 60vh; display: flex; align-items: center;">
      <div class="container text-center">
        <div class="mb-4">
          <i class="bi bi-window-x text-warning" style="font-size: 5rem;"></i>
        </div>
        <h1 class="fw-bold mb-3" style="font-size: 3rem;">404</h1>
        <h2 class="fw-bold mb-3">Page Not Found</h2>
        <p class="text-muted mb-4" style="max-width: 500px; margin: 0 auto;">
          The page may have been moved or the link is incorrect. Return to the homepage or contact us for a consultation.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
          <a href="/en/" class="btn btn-warning px-4 py-3 fw-bold"><i class="bi bi-house me-2"></i> Home</a>
          <a href="/en/contact" class="btn btn-outline-dark px-4 py-3 fw-bold"><i class="bi bi-telephone me-2"></i> Contact Us</a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</BaseLayout>
