---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactModal from '../../components/ContactModal.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "UWS — Window Installation & Repair Kyiv",
  "image": "https://uws.com.ua/assets/img/logo.png",
  "telephone": [
    "+380660575202",
    "+380989478772",
    "+380633664769"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "",
    "addressLocality": "Kyiv",
    "addressRegion": "Kyiv Oblast",
    "postalCode": "01001",
    "addressCountry": "UA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 50.4501,
    "longitude": 30.5234
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "09:00",
    "closes": "20:00"
  },
  "description": "Professional repair, adjustment and installation of PVC windows in Kyiv. Answers to frequently asked questions, warranty up to 5 years.",
  "url": "https://uws.com.ua/en/faq",
  "priceRange": "$$",
  "sameAs": [
    "https://www.facebook.com/uws.kyiv",
    "https://www.instagram.com/uws_kyiv"
  ]
};

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="faq" class="faq py-5">
      <div class="container" data-aos="fade-up">

        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Frequently Asked Questions (FAQ) about Window Repair, Adjustment & Installation
            in Kyiv</h1>
          <p class="lead text-muted mt-3">Answers to the most common questions from UWS clients. Didn't find your question?
            Give us a call — our specialist will advise you for free!</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="nav-panel sticky-top" style="top: 100px; z-index: 10;">
              <div class="bg-white p-4 shadow-sm rounded-4 border-start border-4 border-warning">
                <h4 class="fw-bold mb-4">Question Categories</h4>
                <div class="list-group list-group-flush faq-nav-list" id="faq-nav">
                  <a href="#cat-1"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-tools text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Repair & Service</span>
                  </a>
                  <a href="#cat-2"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-moisture text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Condensation & Cold</span>
                  </a>
                  <a href="#cat-3"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-shield-check text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Hardware & Locks</span>
                  </a>
                  <a href="#cat-4"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-window-split text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Glass Units & Screens</span>
                  </a>
                  <a href="#cat-5"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-wallet2 text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Payment & eVidnovlennia</span>
                  </a>
                  <a href="#cat-6"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-house-gear text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Operation & Care</span>
                  </a>
                </div>
                <div class="mt-4 p-3 rounded-4 border shadow-sm" style="background-color: #f8f9fa;">
                  <p class="small fw-bold mb-3 text-center" style="color: #2a3d47;">Need a consultation?</p>

                  <div class="d-flex flex-column gap-2">
                    <div class="d-flex gap-2">
                      <a href="https://t.me/+380730705280" class="btn btn-sm text-white flex-fill fw-bold py-2"
                        style="background-color: #0088cc; border-radius: 8px;">
                        <i class="bi bi-telegram"></i> Telegram
                      </a>
                      <a href="viber://chat?number=%2B380730705280" class="btn btn-sm text-white flex-fill fw-bold py-2"
                        style="background-color: #7360f2; border-radius: 8px;">
                        <i class="bi bi-chat-dots"></i> Viber
                      </a>
                    </div>
                    <a href="tel:+380660575202" class="btn btn-sm btn-warning fw-bold py-2 text-dark"
                      style="border-radius: 8px;">
                      <i class="bi bi-telephone-outbound me-1"></i> Call Our Specialist
                    </a>

                    <hr class="my-2 opacity-10">

                    <a href="/en/contact#contact" class="btn btn-outline-dark btn-sm fw-bold py-2"
                      style="border-radius: 8px;">
                      All Contacts
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-8">
            <div class="accordion accordion-flush" id="faqlist">

              <div id="cat-1" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-tools text-warning me-2"></i> Repair & Service</h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q1">Do you provide service outside Kyiv?</button>
                    </h3>
                    <div id="q1" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, we work throughout Kyiv and the entire Kyiv region (Bucha,
                        Irpin, Brovary, Boryspil, etc.).</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q2">How much does a technician visit cost?</button>
                    </h3>
                    <div id="q2" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">A technician visit with diagnostics costs 200-300 UAH, but if
                        repairs are carried out, this amount is usually included in the total cost of the work.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q3">Do you repair wooden windows?</button>
                    </h3>
                    <div id="q3" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">We specialize in PVC, aluminum, and modern European-style wooden
                        windows with glass units. We do not service old Soviet-era windows.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q4">How quickly can a technician arrive?</button>
                    </h3>
                    <div id="q4" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">On average, a visit is scheduled on the same day or the next day
                        after the request is submitted.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q5">Can you do same-day repairs?</button>
                    </h3>
                    <div id="q5" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Simple tasks (adjustment, handle replacement) are completed
                        immediately. Glass unit or seal replacement requires manufacturing or sourcing materials.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q6">Do you service sliding systems?</button>
                    </h3>
                    <div id="q6" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, we service tilt-and-slide (PSK) and lift-and-slide
                        (HS) systems.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q7">What tools does the technician use?</button>
                    </h3>
                    <div id="q7" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">We use professional key sets, laser levels, and a thermal
                        imaging camera when necessary.</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="cat-2" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-moisture text-warning me-2"></i> Condensation & Cold</h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q8">Why do windows fog up on the inside?</button>
                    </h3>
                    <div id="q8" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Due to high humidity and poor ventilation. A weak single-chamber
                        glass unit can also be the cause.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q9">There's a draft near the hinges — what should I do?</button>
                    </h3>
                    <div id="q9" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">The middle lock pressure needs to be adjusted, or
                        the seal near the hinge needs to be inspected for damage.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q10">Does energy-saving film help?</button>
                    </h3>
                    <div id="q10" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">This is a temporary solution. It's better to replace the glass
                        unit with an energy-efficient one with argon gas and i-coating.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q11">What is a thermal bridge?</button>
                    </h3>
                    <div id="q11" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">It's an area (usually the reveal or windowsill) through which
                        the most heat is lost due to poor installation seam insulation.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q12">Why does ice form on the windowsill?</button>
                    </h3>
                    <div id="q12" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">This is critical freezing caused by a strong draft or
                        lack of sealing beneath the exterior sill flashing.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q13">How to remove mold from window reveals?</button>
                    </h3>
                    <div id="q13" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">The cause of freezing must be eliminated, the area treated with
                        antiseptic, and the exhaust ventilation system checked.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q14">Can I insulate an already installed window?</button>
                    </h3>
                    <div id="q14" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, by replacing the glass unit with a double-chamber one and
                        replacing the seal with a thicker/higher quality one.</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="cat-3" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-shield-check text-warning me-2"></i> Hardware & Locks</h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q15">The window handle rotates 360 degrees — what's wrong?</button>
                    </h3>
                    <div id="q15" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">The main locking mechanism (gearbox) is broken. It needs to be
                        replaced.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q16">The window opened in two modes simultaneously — what do I do?</button>
                    </h3>
                    <div id="q16" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Press the sash against the frame, press the blocker on
                        the hardware, and turn the handle to the horizontal position.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q17">Can you install a child safety lock?</button>
                    </h3>
                    <div id="q17" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, there are handles with a key or special blockers (child
                        safety locks) for the lower part of the sash.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q18">How often do handles need to be replaced?</button>
                    </h3>
                    <div id="q18" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Handles are only replaced in case of mechanical damage or
                        if you want to change the color/design.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q19">What is anti-burglary hardware?</button>
                    </h3>
                    <div id="q19" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">This is hardware with mushroom-shaped cam locks that cannot be
                        pried open from the outside with a crowbar.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q20">Can you convert a standard opening to tilt-and-turn?</button>
                    </h3>
                    <div id="q20" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, by adding a scissor mechanism to the existing
                        hardware.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q21">The handle is very stiff — is this normal?</button>
                    </h3>
                    <div id="q21" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">No, this indicates the hardware needs lubrication or
                        the window has sagged and is catching on the frame.</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="cat-4" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-window-split text-warning me-2"></i> Glass Units & Screens
                </h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q22">Can you replace the glass unit without replacing the entire window?</button>
                    </h3>
                    <div id="q22" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, it takes 15-20 minutes. The old unit is removed, and
                        the new one is installed.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q23">The glass unit cracked on its own — why?</button>
                    </h3>
                    <div id="q23" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Most likely thermal shock (sudden temperature changes) or
                        frame misalignment during building settling.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q24">Which is better: double-chamber or energy-saving unit?</button>
                    </h3>
                    <div id="q24" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">The best option is a double-chamber unit with energy-saving
                        coating. This is the "gold standard" for Ukraine.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q25">How is the "Anti-cat" screen different?</button>
                    </h3>
                    <div id="q25" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">It has a metal or ultra-strong synthetic mesh that
                        animals cannot tear with their claws.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q26">Do you make magnetic screens?</button>
                    </h3>
                    <div id="q26" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">We make framed, door-mounted (hinged), and roller
                        shutter screens.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q27">Can I order tinted glass units?</button>
                    </h3>
                    <div id="q27" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, we offer glass units with mirror or colored
                        tinting.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q28">The glass unit is fogging INSIDE (between the panes) — what does this mean?</button>
                    </h3>
                    <div id="q28" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">This is a seal failure. Such a glass unit cannot be
                        repaired — it can only be replaced.</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="cat-5" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-wallet2 text-warning me-2"></i> Payment & eVidnovlennia</h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q29">What payment methods do you accept?</button>
                    </h3>
                    <div id="q29" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Cash, bank card transfer, cashless payment (for
                        legal entities), and payment with the eVidnovlennia card.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q30">Is a prepayment required?</button>
                    </h3>
                    <div id="q30" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">For adjustments — no. For ordering glass units or new
                        windows — typically 50-70%.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q31">How do I find you in the eVidnovlennia program?</button>
                    </h3>
                    <div id="q31" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Our manager will provide you with all the necessary details for
                        making a payment through the Diia app or your bank.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q32">Do you issue receipts?</button>
                    </h3>
                    <div id="q32" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, we provide a contract and work completion certificates
                        that confirm payment.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q33">Do you offer discounts for pensioners?</button>
                    </h3>
                    <div id="q33" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, we offer a permanent 10% discount for pensioners and
                        internally displaced persons (IDPs).</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q34">Do you work under a contract?</button>
                    </h3>
                    <div id="q34" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, for all major projects (glass unit replacement,
                        window replacement) an official contract is signed.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q35">Can I pay in installments?</button>
                    </h3>
                    <div id="q35" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">This is discussed individually for large-scale
                        projects.</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="cat-6" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-house-gear text-warning me-2"></i> Operation & Care
                </h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q36">What should I use to clean PVC profiles?</button>
                    </h3>
                    <div id="q36" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">A regular soapy solution. Avoid aggressive solvents
                        and abrasive powders.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q37">How do I switch windows to "winter mode"?</button>
                    </h3>
                    <div id="q37" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">You need to turn the cams on the sash edge so the marking
                        faces the room. However, it's better to call a specialist to avoid over-tightening the seal.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q38">How do I remove yellowing from PVC?</button>
                    </h3>
                    <div id="q38" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">If the profile has yellowed from sun exposure (cheap plastic),
                        it's almost impossible to fix. If it's dirt, professional cleaners (e.g., Cosmofen) will help.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q39">Can PVC windows be painted?</button>
                    </h3>
                    <div id="q39" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Yes, with special PVC paints, but this requires
                        professional equipment.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q40">What are the holes on the outer side of the frame for?</button>
                    </h3>
                    <div id="q40" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">These are drainage holes for diverting water that may get
                        inside the profile.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q41">Why do windows squeak when opening?</button>
                    </h3>
                    <div id="q41" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Dirt in the hinges or lack of lubrication. Cleaning and
                        servicing are required.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q42">Can I install an air conditioner if the window doesn't open?</button>
                    </h3>
                    <div id="q42" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">It's better to convert the fixed sash section to an
                        operable one before installing the air conditioner.</div>
                    </div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="contact py-0 pb-5" data-aos="fade-up">
      <div class="container">
        <div class="p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
          style="background: linear-gradient(135deg, #2a3d47 0%, #1a252b 100%); border: 1px solid rgba(254, 185, 0, 0.3);">

          <div class="position-absolute"
            style="top: -50px; right: -50px; width: 150px; height: 150px; background: #feb900; opacity: 0.05; border-radius: 50%;">
          </div>

          <div class="position-relative">
            <div class="mb-4">
              <i class="bi bi-patch-question text-warning" style="font-size: 3.5rem;"></i>
            </div>

            <h3 class="text-white mb-3" style="font-weight: 700; font-size: 2rem;">
              Your problem isn't on the list?
            </h3>

            <div class="row justify-content-center mb-4">
              <div class="col-lg-8">
                <p class="text-white-50" style="font-size: 1.1rem; line-height: 1.6;">
                  Every case is unique. Describe your situation or <span class="text-white">send a photo/video
                    of the damage</span> via messenger. Our specialist will analyze the issue free of charge and
                  provide an approximate repair cost.
                </p>
              </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
              <a href="/en/contact#contact"
                class="btn btn-warning px-5 py-3 fw-bold shadow text-dark d-inline-flex align-items-center justify-content-center">
                <i class="bi bi-chat-left-text-fill me-2"></i> Get a Consultation
              </a>

              <a href="viber://chat?number=%2B380730705280"
                class="btn btn-outline-light px-5 py-3 fw-bold d-inline-flex align-items-center justify-content-center">
                <i class="bi bi-chat-dots text-warning me-2"></i> Ask on Viber
              </a>
            </div>

            <div class="mt-4 d-flex align-items-center justify-content-center flex-wrap gap-4">
              <div class="d-flex align-items-center text-white-50 small">
                <i class="bi bi-lightning-charge-fill me-2 text-warning"></i> Response in 5-10 minutes
              </div>
              <div class="d-flex align-items-center text-white-50 small">
                <i class="bi bi-camera-fill me-2 text-warning"></i> Photo assessment
              </div>
              <div class="d-flex align-items-center text-white-50 small">
                <i class="bi bi-person-check-fill me-2 text-warning"></i> Expert advice
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="en"
  title={"Frequently Asked Questions (FAQ) | Window Repair & Installation Kyiv — UWS"}
  description={"Most common questions about window repair in Kyiv: adjustment, hardware replacement, condensation, eVidnovlennia, warranty. Answers from UWS specialists. Free consultation by phone."}
  canonicalPath={"/en/faq"}
  structuredData={structuredData}
>
  <Header lang="en" activePage="faq" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="en" />
  <Footer lang="en" />
</BaseLayout>