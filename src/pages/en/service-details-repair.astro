---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactModal from '../../components/ContactModal.astro';
import { getServiceStructuredData } from '../../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Window & Door Repair Kyiv',
  description: 'Professional repair and adjustment of PVC windows and doors in Kyiv. Hardware replacement, seal replacement, servicing. Warranty up to 5 years.',
  url: 'https://uws.com.ua/en/service-details-repair',
  extra: {
    makesOffer: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Window & door repair and adjustment',
      },
    },
  },
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="service-details" class="service-details py-5">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Window & Door Repair and Adjustment in Kyiv</h1>
          <p class="lead text-muted mt-3">UWS — quick fix for drafts, jammed handles, broken hardware. Urgent
            technician dispatch, warranty up to 5 years.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="services-list shadow-sm rounded-4 p-4 bg-white">
              <a href="/en/service-details-install">Window & Door Installation</a>
              <a href="/en/service-details-repair" class="active">Window & Door Repair</a>
              <a href="/en/service-details-balkony">Balconies & Loggias</a>
              <a href="/en/service-details-moskitki">Mosquito Nets</a>
              <a href="/en/service-details-glass">Glass Unit Replacement</a>
              <a href="/en/service-details-dovodyachi">Door Closers</a>
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light shadow-sm">
              <h4 class="fw-bold mb-3">Extend the Life of Your Windows</h4>
              <p class="text-muted">
                Timely adjustment and hardware servicing prevent expensive repairs and keep your home warm.
              </p>
            </div>
          </div>

          <div class="col-lg-8">
            <picture>
              <source srcset="/assets/img/services/repair.webp" type="image/webp">
              <img src="/assets/img/services/repair.jpg" alt="Professional PVC window & door repair in Kyiv — UWS"
              class="img-fluid services-img rounded-4 shadow-sm mb-4" loading="lazy">
            </picture>

            <h2 class="h3 fw-bold mb-4">Professional Window & Door Repair and Servicing</h2>
            <p class="lead text-muted mb-5">
              We specialize in restoring the functionality of PVC structures. From simple adjustment
              to complete hardware replacement — we do it all quickly and with quality.
            </p>

            <h3 class="h4 fw-bold mb-3">Main types of repair:</h3>
            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Sash adjustment:</strong> Fixing sagging, drafts, stiff handle operation.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Hardware replacement:</strong> Full set or individual elements (MACO, Roto, Siegenia).
                </div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Seal replacement:</strong> Installing quality German rubber for airtightness.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Sliding system repair:</strong> Tilt-and-slide (PSK) and lift-and-slide (HS) structures.
                </div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Condensation & frost removal:</strong> Diagnostics and comprehensive solution to the problem.
                </div>
              </li>
            </ul>

            <p class="mt-4 text-muted">
              Our technicians arrive with a full set of tools and parts — most repairs are completed in a single visit.
              Dispatch and diagnostics are free when repair work is performed.
            </p>

            <div class="mt-5 p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
              style="background: linear-gradient(135deg, #364d59 0%, #223139 100%); border: 2px solid #feb900;">

              <div class="position-relative">
                <h3 class="text-white mb-3" style="font-weight: 700;">Window letting in drafts, stiff handle, or jammed shut?</h3>
                <p class="text-white-50 mb-4 lead">
                  Call a technician — diagnostics and most repairs are performed <strong>the same day</strong>.
                </p>

                <a href="/en/contact#contact"
                  class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg text-dark d-inline-flex align-items-center">
                  <i class="bi bi-person-check-fill me-2"></i>
                  Call a repair technician
                </a>

                <div class="mt-4 text-white-50 small">
                  <i class="bi bi-shield-check me-1 text-warning"></i> Warranty on work up to 5 years
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="en"
  title={"Window & Door Repair Kyiv 2026 | Adjustment & Servicing — UWS"}
  description={"Professional PVC window & door repair in Kyiv by UWS: adjustment, hardware replacement, seal replacement. Urgent technician dispatch, warranty up to 5 years. Free diagnostics."}
  canonicalPath={"/en/service-details-repair"}
  structuredData={structuredData}
>
  <Header lang="en" activePage="service-details-repair" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="en" />
  <Footer lang="en" />
</BaseLayout>
