---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactModal from '../../components/ContactModal.astro';
import { getServiceStructuredData } from '../../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Window Installation & Repair Kyiv',
  description: 'Full range of window repair, adjustment, and installation services in Kyiv. Warranty up to 5 years, free on-site technician visit.',
  url: 'https://uws.com.ua/en/services',
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="services" class="services section-bg py-5">
      <div class="container" data-aos="fade-up">

        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Window repair & installation services in Kyiv</h1>
          <p class="lead text-muted mt-3">UWS offers a complete range of uPVC window and door maintenance services.
            Warranty up to 5 years, free on-site technician visit across Kyiv.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/repair.webp" type="image/webp">
                  <img src="/assets/img/services/repair.jpg" class="img-fluid w-100"
                  alt="uPVC window repair Kyiv — adjustment, hardware replacement"
                  style="height: 220px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-tools"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h2 class="h4 fw-bold">Window & door repair</h2>
                <p class="text-muted small">Professional adjustment, hardware and seal replacement. We eliminate drafts
                  and jamming.</p>
                <hr class="my-3 opacity-10">
                <a href="/en/service-details-repair"
                  class="stretched-link text-warning fw-bold text-decoration-none">Learn more <i
                    class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/install.webp" type="image/webm">
                  <img src="/assets/img/services/install.jpg" class="img-fluid w-100"
                  alt="uPVC window and door installation Kyiv" style="height: 220px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-window"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h2 class="h4 fw-bold">Window & door installation</h2>
                <p class="text-muted small">Installation of new uPVC systems to DSTU standards. Energy-efficient glazing for
                  your home.</p>
                <hr class="my-3 opacity-10">
                <a href="/en/service-details-install"
                  class="stretched-link text-warning fw-bold text-decoration-none">Learn more <i
                    class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/glass.webp" type="image/webp">
                  <img src="/assets/img/services/glass.jpg" class="img-fluid w-100"
                  alt="Glass unit replacement in windows Kyiv — energy-saving" style="height: 220px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-box-arrow-up-right"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h2 class="h4 fw-bold">Glass unit replacement</h2>
                <p class="text-muted small">Urgent replacement of broken units or installation of new energy-saving
                  and sound-insulating ones.</p>
                <hr class="my-3 opacity-10">
                <a href="/en/service-details-glass"
                  class="stretched-link text-warning fw-bold text-decoration-none">Learn more <i
                    class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/balkony.webp" type="image/webp">
                  <img src="/assets/img/services/balkony.jpg" class="img-fluid w-100"
                  alt="Balcony and loggia turnkey glazing Kyiv" style="height: 220px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-house-door"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h2 class="h4 fw-bold">Balconies & loggias</h2>
                <p class="text-muted small">Complete glazing, insulation, and finishing. We create a comfortable additional
                  living space.</p>
                <hr class="my-3 opacity-10">
                <a href="/en/service-details-balkony"
                  class="stretched-link text-warning fw-bold text-decoration-none">Learn more <i
                    class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="500">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/moskitki.webp" type="image/webp">
                  <img src="/assets/img/services/moskitki.jpg" class="img-fluid w-100"
                  alt="Mosquito nets for windows and doors Kyiv — Anti-cat" style="height: 220px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-grid-3x3-gap"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h2 class="h4 fw-bold">Mosquito nets</h2>
                <p class="text-muted small">All types of nets: frame, door, "Anti-cat". Made to
                  custom sizes.</p>
                <hr class="my-3 opacity-10">
                <a href="/en/service-details-moskitki"
                  class="stretched-link text-warning fw-bold text-decoration-none">Learn more <i
                    class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="600">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/dovodyachi.webp" type="image/webp">
                  <img src="/assets/img/services/dovodyachi.jpg" class="img-fluid w-100"
                  alt="Door closer installation Kyiv" style="height: 220px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-door-closed"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h2 class="h4 fw-bold">Door closers</h2>
                <p class="text-muted small">Professional selection and installation of closers. Seasonal adjustment and
                  maintenance of mechanisms.</p>
                <hr class="my-3 opacity-10">
                <a href="/en/service-details-dovodyachi"
                  class="stretched-link text-warning fw-bold text-decoration-none">Learn more <i
                    class="bi bi-chevron-right small"></i></a>
              </div>
            </div>
          </div>

        </div>

        <div class="row mt-5" data-aos="fade-up" data-aos-delay="700">
          <div class="col-12">
            <div
