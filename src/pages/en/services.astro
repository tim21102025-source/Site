                  <i class="bi bi-headset"></i>
                </div>
                <div>
                  <h3 class="fw-bold mb-1 text-dark">Couldn't find the service you need?</h3>
                  <p class="mb-0 text-dark opacity-75">Simply call us — we perform any non-standard
                    window repair and maintenance work.</p>
                </div>
              </div>
              <a href="/en/contact"
                class="btn btn-dark btn-lg px-5 py-3 rounded-pill fw-bold shadow">Contact a technician</a>
            </div>
          </div>
        </div>

      </div>
    </section>

    <section id="services-cards" class="services-cards py-5">
      <div class="container" data-aos="fade-up">

        <div class="row gy-4">

          <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="100">
            <div class="info-card h-100 p-4 shadow-sm border-0 rounded-4 bg-white position-relative">
              <div class="icon-box mb-3 text-warning" style="font-size: 2rem;">
                <i class="bi bi-box-seam"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Materials & parts</h3>
              <p class="text-muted small">We use only original components and professional consumable
                materials for long-lasting repairs.</p>
              <ul class="list-unstyled mt-3">
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">EPDM rubber seals</span></li>
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Original lubricants</span></li>
                <li class="d-flex align-items-start"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Professional sealants</span></li>
              </ul>
            </div>
          </div>

          <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="200">
            <div class="info-card h-100 p-4 shadow-sm border-0 rounded-4 bg-white position-relative">
              <div class="icon-box mb-3 text-warning" style="font-size: 2rem;">
                <i class="bi bi-gear-wide-connected"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Any complexity</h3>
              <p class="text-muted small">Our technicians have experience with all types of window and door systems
                available on the market.</p>
              <ul class="list-unstyled mt-3">
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">MACO, Roto, Siegenia</span></li>
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Aluminium and PVC systems</span></li>
                <li class="d-flex align-items-start"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Complex entrance groups</span></li>
              </ul>
            </div>
          </div>

          <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="300">
            <div class="info-card h-100 p-4 shadow-sm border-0 rounded-4 bg-white position-relative">
              <div class="icon-box mb-3 text-warning" style="font-size: 2rem;">
                <i class="bi bi-shield-check"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">UWS warranty</h3>
              <p class="text-muted small">UWS provides an official warranty on all completed work and installed
                components.</p>
              <ul class="list-unstyled mt-3">
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Up to 5 years warranty</span></li>
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Post-warranty support</span></li>
                <li class="d-flex align-items-start"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Loyalty programme</span></li>
              </ul>
            </div>
          </div>

          <div class="col-lg-3 col-md-6" data-aos="zoom-in" data-aos-delay="400">
            <div class="info-card h-100 p-4 shadow-sm border-0 rounded-4 bg-white position-relative">
              <div class="icon-box mb-3 text-warning" style="font-size: 2rem;">
                <i class="bi bi-cash-stack"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Transparent service</h3>
              <p class="text-muted small">No hidden fees. The cost of work is agreed upon before repairs begin
                after diagnostics.</p>
              <ul class="list-unstyled mt-3">
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Fixed pricing</span></li>
                <li class="d-flex align-items-start mb-2"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Pay upon completion</span></li>
                <li class="d-flex align-items-start"><i class="bi bi-check2-circle text-warning me-2"></i> <span
                    class="small">Cash / bank transfer payment</span></li>
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="alt-services-2" class="alt-services section-bg py-5">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-around gy-4">
          <div class="col-lg-5 d-flex flex-column justify-content-center">
            <h2 class="fw-bold mb-4">Free consultation & technician call for diagnostics</h2>
            <p class="text-muted mb-5">Our specialists will help identify the cause of the malfunction remotely or will come
              for a detailed inspection at a time convenient for you.</p>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="100">
              <i class="bi bi-chat-text flex-shrink-0"></i>
              <div>
                <h4><a href="/en/contact" class="stretched-link">24/7 communication</a></h4>
                <p>We accept requests via our website and messengers around the clock.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="200">
              <i class="bi bi-truck flex-shrink-0"></i>
              <div>
                <h4><a href="/en/contact" class="stretched-link">Fast dispatch</a></h4>
                <p>A technician can be at your location within 2–3 hours of your call (depending on the area).</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="300">
