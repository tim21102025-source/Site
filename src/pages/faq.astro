  description={"Найпоширеніші питання про ремонт вікон у Києві: регулювання, заміна фурнітури, конденсат, єВідновлення, гарантія. Відповіді від майстрів UWS. Безкоштовна консультація за телефоном."}
  canonicalPath={"/faq"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="faq" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
