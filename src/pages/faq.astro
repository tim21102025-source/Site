---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type": "Question", "name": "Чи виїжджаєте ви за межі Києва?", "acceptedAnswer": {"@type": "Answer", "text": "Так, ми працюємо по Києву та всій Київській області (Буча, Ірпінь, Бровари, Бориспіль тощо)."}},
    {"@type": "Question", "name": "Скільки коштує виклик майстра?", "acceptedAnswer": {"@type": "Answer", "text": "Виїзд майстра з діагностикою коштує 200-300 грн, але при виконанні ремонту — безкоштовно."}},
    {"@type": "Question", "name": "Ви ремонтуєте дерев'яні вікна?", "acceptedAnswer": {"@type": "Answer", "text": "Ми спеціалізуємося на металопластикових, алюмінієвих та сучасних дерев'яних вікнах з ПВХ-профілем."}},
    {"@type": "Question", "name": "Як швидко приїде майстер?", "acceptedAnswer": {"@type": "Answer", "text": "В середньому виїзд здійснюється протягом дня або на наступний день після звернення."}},
    {"@type": "Question", "name": "Чи можна зробити ремонт в день звернення?", "acceptedAnswer": {"@type": "Answer", "text": "Прості роботи (регулювання, заміна ручки) виконуються одразу. Заміна склопакета — протягом 1-2 днів."}},
    {"@type": "Question", "name": "Чи ремонтуєте ви розсувні системи?", "acceptedAnswer": {"@type": "Answer", "text": "Так, ми обслуговуємо похило-зсувні (PSK) та підйомно-зсувні (HS) системи."}},
    {"@type": "Question", "name": "Які інструменти використовує майстер?", "acceptedAnswer": {"@type": "Answer", "text": "Використовуємо професійні набори ключів, лазерні рівні та за потреби тепловізор."}},
    {"@type": "Question", "name": "Чому вікна пітніють зсередини?", "acceptedAnswer": {"@type": "Answer", "text": "Через високу вологість та погану вентиляцію. Також причиною може бути слабкий притиск стулки."}},
    {"@type": "Question", "name": "З вікна дує з боку петель, що робити?", "acceptedAnswer": {"@type": "Answer", "text": "Потрібно відрегулювати притиск середнього замка або перевірити цілісність ущільнювача."}},
    {"@type": "Question", "name": "Чи допомагає енергозберігаюча плівка?", "acceptedAnswer": {"@type": "Answer", "text": "Це тимчасове рішення. Краще замінити склопакет на енергоефективний з аргоном."}},
    {"@type": "Question", "name": "Що таке місток холоду?", "acceptedAnswer": {"@type": "Answer", "text": "Це ділянка (зазвичай відкос або підвіконня), через яку йде найбільша втрата тепла."}},
    {"@type": "Question", "name": "Чому на підвіконні з'являється лід?", "acceptedAnswer": {"@type": "Answer", "text": "Це критичне промерзання через сильний протяг або відсутність герметизації підвіконня."}},
    {"@type": "Question", "name": "Як прибрати плісняву на відкосах?", "acceptedAnswer": {"@type": "Answer", "text": "Потрібно усунути причину промерзання, обробити антисептиком та перевірити роботу вентиляції."}},
    {"@type": "Question", "name": "Чи можна утеплити вже встановлене вікно?", "acceptedAnswer": {"@type": "Answer", "text": "Так, через заміну склопакета на двокамерний та заміну ущільнювача на більш щільний."}},
    {"@type": "Question", "name": "Ручка вікна прокручується на 360 градусів, що це?", "acceptedAnswer": {"@type": "Answer", "text": "Зламався основний запор (редуктор). Потрібна його заміна."}},
    {"@type": "Question", "name": "Вікно відкрилося одночасно у двох режимах, що робити?", "acceptedAnswer": {"@type": "Answer", "text": "Притисніть стулку до рами, натисніть блокіратор на фурнітурі та поверніть ручку."}},
    {"@type": "Question", "name": "Чи можна встановити замок від дітей?", "acceptedAnswer": {"@type": "Answer", "text": "Так, є ручки з ключем або спеціальні блокіратори (дитячі замки) на нижню частину стулки."}},
    {"@type": "Question", "name": "Як часто потрібно міняти ручки?", "acceptedAnswer": {"@type": "Answer", "text": "Ручки міняються тільки при механічній поломці або якщо ви хочете змінити колір."}},
    {"@type": "Question", "name": "Що таке протизламна фурнітура?", "acceptedAnswer": {"@type": "Answer", "text": "Це фурнітура з грибоподібними цапфами, які неможливо віджати ломом зовні."}},
    {"@type": "Question", "name": "Чи можна змінити звичайне відкривання на похило-поворотне?", "acceptedAnswer": {"@type": "Answer", "text": "Так, шляхом доукомплектування фурнітури механізмом ножиць."}},
    {"@type": "Question", "name": "Ручка закривається дуже туго, це нормально?", "acceptedAnswer": {"@type": "Answer", "text": "Ні, це ознака того, що фурнітура потребує змащування або вікно просіло і потребує регулювання."}},
    {"@type": "Question", "name": "Чи можна поміняти склопакет без заміни вікна?", "acceptedAnswer": {"@type": "Answer", "text": "Так, це займає 15-20 хвилин. Старий виймається, новий ставиться."}},
    {"@type": "Question", "name": "Склопакет тріснув сам по собі, чому?", "acceptedAnswer": {"@type": "Answer", "text": "Найімовірніше — термошок (різкий перепад температур) або перекіс рами під час монтажу."}},
    {"@type": "Question", "name": "Що краще: двокамерний чи енергозберігаючий пакет?", "acceptedAnswer": {"@type": "Answer", "text": "Найкраще — двокамерний з енергозберігаючим напиленням. Це 'золотий стандарт'."}},
    {"@type": "Question", "name": "Чим відрізняється сітка 'Антикішка'?", "acceptedAnswer": {"@type": "Answer", "text": "Вона має металеве або надміцне синтетичне полотно, яке тварина не зможе розрізати."}},
    {"@type": "Question", "name": "Чи робите ви сітки на магнітах?", "acceptedAnswer": {"@type": "Answer", "text": "Ми робимо рамкові, дверні (на петлях) та ролетні сітки."}},
    {"@type": "Question", "name": "Чи можна замовити тонований склопакет?", "acceptedAnswer": {"@type": "Answer", "text": "Так, ми пропонуємо склопакети з дзеркальним або кольоровим тонуванням."}},
    {"@type": "Question", "name": "Склопакет пітніє ВСЕРЕДИНІ (між склом), що це?", "acceptedAnswer": {"@type": "Answer", "text": "Це розгерметизація. Такий склопакет не підлягає ремонту, тільки заміні."}},
    {"@type": "Question", "name": "Які форми оплати ви приймаєте?", "acceptedAnswer": {"@type": "Answer", "text": "Готівка, переказ на карту, безготівковий розрахунок (для юр. осіб) та оплата через єВідновлення."}},
    {"@type": "Question", "name": "Чи потрібна передоплата?", "acceptedAnswer": {"@type": "Answer", "text": "Для регулювання — ні. Для замовлення склопакетів або нових вікон — зазвичай передоплата 50%."}},
    {"@type": "Question", "name": "Як знайти вас у програмі єВідновлення?", "acceptedAnswer": {"@type": "Answer", "text": "Наш менеджер надасть вам всі необхідні реквізити для проведення оплати через державну програму."}},
    {"@type": "Question", "name": "Чи видаєте ви чеки?", "acceptedAnswer": {"@type": "Answer", "text": "Так, ми надаємо договір та акти виконаних робіт, які підтверджують факт оплати."}},
    {"@type": "Question", "name": "Чи є знижки для пенсіонерів?", "acceptedAnswer": {"@type": "Answer", "text": "Так, у нас діє постійна знижка 10% для пенсіонерів та ВПО."}},
    {"@type": "Question", "name": "Чи працюєте ви за договором?", "acceptedAnswer": {"@type": "Answer", "text": "Так, на всі великі роботи (заміна склопакетів, вікон) укладається офіційний договір."}},
    {"@type": "Question", "name": "Чи можна платити частинами?", "acceptedAnswer": {"@type": "Answer", "text": "Обговорюється індивідуально для великих об'єктів."}},
    {"@type": "Question", "name": "Чим мити пластикові профілі?", "acceptedAnswer": {"@type": "Answer", "text": "Звичайним мильним розчином. Уникайте агресивних розчинників та абразивних засобів."}},
    {"@type": "Question", "name": "Як перевести вікна в 'зимовий режим'?", "acceptedAnswer": {"@type": "Answer", "text": "Потрібно повернути цапфи на торці стулки позначкою в бік приміщення. Але краще викликати майстра."}},
    {"@type": "Question", "name": "Як прибрати жовтизну з пластику?", "acceptedAnswer": {"@type": "Answer", "text": "Якщо профіль пожовтів від сонця (дешевий пластик), прибрати це майже неможливо."}},
    {"@type": "Question", "name": "Чи можна фарбувати пластикові вікна?", "acceptedAnswer": {"@type": "Answer", "text": "Так, спеціальними фарбами для ПВХ, але це потребує професійного обладнання."}},
    {"@type": "Question", "name": "Навіщо потрібні отвори на зовнішній стороні рами?", "acceptedAnswer": {"@type": "Answer", "text": "Це дренажні отвори для відведення води, яка може потрапити всередину профілю."}},
    {"@type": "Question", "name": "Чому вікна скриплять при відкриванні?", "acceptedAnswer": {"@type": "Answer", "text": "Бруд у петлях або відсутність мастила. Потрібне чищення та сервіс."}},
    {"@type": "Question", "name": "Чи можна ставити кондиціонер, якщо вікно не відкривається?", "acceptedAnswer": {"@type": "Answer", "text": "Краще переробити глуху частину стулки на відкривну перед монтажем кондиціонера."}}
  ]
};

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="faq" class="faq py-5">
      <div class="container" data-aos="fade-up">

        <!-- Головний заголовок сторінки H1 -->
        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Питання та відповіді (FAQ) про ремонт, регулювання та встановлення
            вікон у Києві</h1>
          <p class="lead text-muted mt-3">Відповіді на найпоширеніші запитання клієнтів UWS. Не знайшли своє питання?
            Зателефонуйте — майстер проконсультує безкоштовно!</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="nav-panel sticky-top" style="top: 100px; z-index: 10;">
              <div class="bg-white p-4 shadow-sm rounded-4 border-start border-4 border-warning">
                <h4 class="fw-bold mb-4">Розділи питань</h4>
                <div class="list-group list-group-flush faq-nav-list" id="faq-nav">
                  <a href="#cat-1"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-tools text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Ремонт та сервіс</span>
                  </a>
                  <a href="#cat-2"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-moisture text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Конденсат та холод</span>
                  </a>
                  <a href="#cat-3"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-shield-check text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Фурнітура та замки</span>
                  </a>
                  <a href="#cat-4"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-window-split text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Склопакети та сітки</span>
                  </a>
                  <a href="#cat-5"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-wallet2 text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Оплата та єВідновлення</span>
                  </a>
                  <a href="#cat-6"
                    class="list-group-item list-group-item-action border-0 d-flex align-items-center py-3 rounded-3 mb-1">
                    <i class="bi bi-house-gear text-warning me-3 fs-5"></i>
                    <span class="fw-medium" style="color: #2a3d47;">Експлуатація та догляд</span>
                  </a>
                </div>
                <div class="mt-4 p-3 rounded-4 border shadow-sm" style="background-color: #f8f9fa;">
                  <p class="small fw-bold mb-3 text-center" style="color: #2a3d47;">Потрібна консультація?</p>

                  <div class="d-flex flex-column gap-2">
                    <div class="d-flex gap-2">
                      <a href="https://t.me/+380730705280" class="btn btn-sm text-white flex-fill fw-bold py-2"
                        style="background-color: #0088cc; border-radius: 8px;">
                        <i class="bi bi-telegram"></i> Telegram
                      </a>
                      <a href="viber://chat?number=%2B380730705280" class="btn btn-sm text-white flex-fill fw-bold py-2"
                        style="background-color: #7360f2; border-radius: 8px;">
                        <i class="bi bi-chat-dots"></i> Viber
                      </a>
                    </div>
                    <a href="tel:+380660575202" class="btn btn-sm btn-warning fw-bold py-2 text-dark"
                      style="border-radius: 8px;">
                      <i class="bi bi-telephone-outbound me-1"></i> Зателефонувати майстру
                    </a>

                    <hr class="my-2 opacity-10">

                    <a href="/contact" class="btn btn-outline-dark btn-sm fw-bold py-2"
                      style="border-radius: 8px;">
                      Всі контакти
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-8">
            <div class="accordion accordion-flush" id="faqlist">

              <div id="cat-1" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-tools text-warning me-2"></i> Ремонт та сервіс</h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q1">Чи виїжджаєте ви за межі Києва?</button>
                    </h3>
                    <div id="q1" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Так, ми працюємо по Києву та всій Київській області (Буча,
                        Ірпінь, Бровари, Бориспіль тощо).</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q2">Скільки коштує виклик майстра?</button>
                    </h3>
                    <div id="q2" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Виїзд майстра з діагностикою коштує 200-300 грн, але при
                        виконанні ремонту ця сума зазвичай входить у вартість робіт.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q3">Ви ремонтуєте дерев'яні вікна?</button>
                    </h3>
                    <div id="q3" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Ми спеціалізуємося на металопластикових, алюмінієвих та
                        сучасних дерев'яних євровікнах зі склопакетами. Старі радянські вікна не обслуговуємо.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q4">Як швидко приїде майстер?</button>
                    </h3>
                    <div id="q4" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">В середньому виїзд здійснюється протягом дня або на
                        наступний день після заявки.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q5">Чи можна зробити ремонт в день звернення?</button>
                    </h3>
                    <div id="q5" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Прості роботи (регулювання, заміна ручки) виконуються
                        одразу. Заміна склопакета або ущільнювача потребує виготовлення або підбору матеріалу.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q6">Чи ремонтуєте ви розсувні системи?</button>
                    </h3>
                    <div id="q6" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Так, ми обслуговуємо похило-зсувні (PSK) та підйомно-зсувні
                        (HS) системи.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q7">Які інструменти використовує майстер?</button>
                    </h3>
                    <div id="q7" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Використовуємо професійні набори ключів, лазерні рівні та
                        за потреби тепловізор.</div>
                    </div>
                  </div>
                </div>
              </div>

              <div id="cat-2" class="pt-2 mb-5">
                <h2 class="fw-bold mb-4 h4"><i class="bi bi-moisture text-warning me-2"></i> Конденсат та холод</h2>
                <div class="faq-group">
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
                      <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse"
                        data-bs-target="#q8">Чому вікна пітніють зсередини?</button>
                    </h3>
                    <div id="q8" class="accordion-collapse collapse" data-bs-parent="#faqlist">
                      <div class="accordion-body text-muted">Через високу вологість та погану вентиляцію. Також причиною
                        може бути слабкий однокамерний склопакет.</div>
                    </div>
                  </div>
                  <div class="accordion-item shadow-sm mb-3 rounded-3 border">
                    <h3 class="accordion-header">
