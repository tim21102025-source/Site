        <i class="bi bi-telephone-fill me-1"></i> Зателефонувати
      </a>
      <a href="#form" class="btn btn-sm fw-bold px-3 py-2 text-white flex-grow-1 d-flex align-items-center justify-content-center" style="border-radius: 8px; font-size: 13px; background: #feb900; color: #1a252b;">
        <i class="bi bi-send me-1"></i> Залишити заявку
      </a>
