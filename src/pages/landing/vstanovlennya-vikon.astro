  <!-- Sticky CTA bar (bottom) -->
  <div id="sticky-cta" style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 999; background: rgba(26,37,43,0.97); backdrop-filter: blur(12px); border-top: 1px solid rgba(254,185,0,0.3); padding: 10px 0; transform: translateY(100%); transition: transform 0.3s ease;">
