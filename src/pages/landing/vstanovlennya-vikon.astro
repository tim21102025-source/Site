  <script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const state = { type: '7500', qty: 1, demontazh: true, pidvikonnya: true };
    const typeNames = { '5500': 'Стандартне', '7500': 'Енергозберігаюче', '9500': 'Шумозахисне' };
    const typePrices = { '5500': 5500, '7500': 7500, '9500': 9500 };
    let selectedPackage = null;

    // Smooth scroll
    document.querySelectorAll('a[href="#form"], a[href="#calculator"]').forEach(a => {
      a.addEventListener('click', e => { e.preventDefault(); document.getElementById(a.getAttribute('href').slice(1))?.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
    });

    // Sticky CTA + summary
    const stickyCta = document.getElementById('sticky-cta');
    const calcSection = document.getElementById('calculator');
    const formSection = document.getElementById('form');
    const summaryEl = document.getElementById('calc-summary');
    window.addEventListener('scroll', () => {
      if (stickyCta) {
        const calcRect = calcSection?.getBoundingClientRect();
        const formTop = formSection?.offsetTop || Infinity;
        if ((calcRect && calcRect.bottom > 100) || window.scrollY > formTop - 600) stickyCta.style.transform = 'translateY(100%)';
        else stickyCta.style.transform = window.scrollY > 400 ? 'translateY(0)' : 'translateY(100%)';
      }
      if (summaryEl && calcSection) {
        const calcRect = calcSection.getBoundingClientRect();
        const formTop = formSection?.offsetTop || Infinity;
        summaryEl.classList.toggle('d-none', !(calcRect.bottom < 0 && window.scrollY < formTop - 200));
      }
    });

    // Calculator type cards
    document.querySelectorAll('.calc-card').forEach(card => {
      card.addEventListener('click', () => {
        state.type = card.dataset.value;
        document.querySelectorAll('.calc-card').forEach(c => { c.style.borderColor = '#e9ecef'; c.style.background = 'transparent'; });
        card.style.borderColor = '#feb900';
        card.style.background = 'rgba(254,185,0,0.04)';
        updateDisplay();
      });
    });

    // Quantity
    window.calcQty = function(d) { state.qty = Math.max(1, Math.min(20, state.qty + d)); document.getElementById('calc-qty').textContent = state.qty; updateDisplay(); };
    window.setQty = function(v) { state.qty = Math.max(1, Math.min(20, v)); document.getElementById('calc-qty').textContent = state.qty; updateDisplay(); };

    // Options
    document.querySelectorAll('.calc-option').forEach(opt => {
      opt.addEventListener('click', () => {
        const key = opt.dataset.option;
        state[key] = !state[key];
        const check = opt.querySelector('.calc-option-check');
        const icon = opt.querySelector('i');
        opt.style.borderColor = state[key] ? '#feb900' : '#e9ecef';
        opt.style.background = state[key] ? 'rgba(254,185,0,0.04)' : 'transparent';
        check.style.background = state[key] ? '#feb900' : 'transparent';
        check.style.borderColor = state[key] ? '#feb900' : '#dee2e6';
        icon.style.color = state[key] ? '#1a252b' : 'transparent';
        updateDisplay();
      });
    });

    // Тільки оновлює візуал — НЕ чіпає textarea
    function updateDisplay() {
      const price = typePrices[state.type];
      const dCost = state.demontazh ? 500 : 0;
      const pCost = state.pidvikonnya ? 800 : 0;
      const total = (price + dCost + pCost) * state.qty;

      const totalEl = document.getElementById('calc-total');
      const cur = parseInt(totalEl.textContent.replace(/\s/g, ''));
      const diff = total - cur;
      if (diff !== 0) {
        let s = 0; const inc = diff / 20;
        const iv = setInterval(() => { s++; totalEl.textContent = Math.round(cur + inc * s).toLocaleString('uk-UA'); if (s >= 20) { totalEl.textContent = total.toLocaleString('uk-UA'); clearInterval(iv); } }, 15);
      }

      let parts = [price.toLocaleString('uk-UA') + (state.qty > 1 ? ' × ' + state.qty : '')];
      if (state.demontazh) parts.push('+' + (dCost * state.qty).toLocaleString('uk-UA') + ' демонтаж');
      if (state.pidvikonnya) parts.push('+' + (pCost * state.qty).toLocaleString('uk-UA') + ' підвіконня');
      document.getElementById('calc-breakdown').textContent = parts.join('  ');

      document.getElementById('summary-type').textContent = typeNames[state.type];
      document.getElementById('summary-qty').textContent = state.qty;
      document.getElementById('summary-total').textContent = total.toLocaleString('uk-UA') + ' грн';
    }

    // Будує повідомлення з калькулятора
    function buildCalcMessage() {
      const price = typePrices[state.type];
      const dCost = state.demontazh ? 500 : 0;
      const pCost = state.pidvikonnya ? 800 : 0;
      const total = (price + dCost + pCost) * state.qty;
      let msg = 'Розрахунок з калькулятора:\nТип: ' + typeNames[state.type] + '\nКількість: ' + state.qty + ' вікон\n';
      if (state.demontazh) msg += 'Демонтаж: так (+' + (dCost * state.qty).toLocaleString('uk-UA') + ' грн)\n';
      if (state.pidvikonnya) msg += 'Підвіконня + відливи: так (+' + (pCost * state.qty).toLocaleString('uk-UA') + ' грн)\n';
      msg += 'Орієнтовна сума: ' + total.toLocaleString('uk-UA') + ' грн\nПрошу розрахувати точну вартість';
      return msg;
    }

    // "Отримати розрахунок" — прив'язує дані калькулятора
    document.getElementById('btn-calc-submit').addEventListener('click', (e) => {
      e.preventDefault();
      const msg = buildCalcMessage();
      document.getElementById('calc-data-input').value = msg;
      showFormBadge();
      document.getElementById('form').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Пакети "Ціни на встановлення" — прив'язує вибір
    document.querySelectorAll('.pkg-select-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        selectedPackage = btn.dataset.package;
        document.getElementById('calc-data-input').value = 'Обраний пакет: ' + selectedPackage;
        showFormBadge();
        document.getElementById('form').scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Показує бейдж що дані прив'язані
    function showFormBadge() {
      const badge = document.getElementById('calc-badge');
      if (badge) {
        badge.classList.remove('d-none');
        badge.innerHTML = '<span class="badge bg-success text-white px-2 py-1 rounded-pill" style="font-size: 10px;"><i class="bi bi-check-circle me-1"></i>дані прив\'язано</span>';
      }
    }

    updateDisplay();

    const dateStr = new Date(Date.now() + 7 * 86400000).toLocaleDateString('uk-UA', { day: 'numeric', month: 'long' });
    document.getElementById('hero-deadline').textContent = dateStr;

    const obs = new IntersectionObserver((es) => { es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('fade-in-visible'); obs.unobserve(e.target); } }); }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  });
  </script>

  <style>
    .cursor-pointer { cursor: pointer; }
    .fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in-visible { opacity: 1; transform: translateY(0); }
    .calc-card:hover { border-color: #feb900 !important; box-shadow: 0 4px 16px rgba(254,185,0,0.15); }
    .calc-qty-btn:hover { border-color: #feb900 !important; color: #feb900 !important; background: rgba(254,185,0,0.06) !important; }
    .calc-qty-btn:active { transform: scale(0.92); }
    .calc-option:hover { border-color: #feb900 !important; }
    #calc-total { transition: color 0.3s; }
    .calc-result { position: relative; overflow: hidden; }
    .calc-result::before { content: ''; position: absolute; top: -50%; right: -20%; width: 200px; height: 200px; background: radial-gradient(circle, rgba(254,185,0,0.08) 0%, transparent 70%); pointer-events: none; }
    .telegram-form .form-control:focus,
    .telegram-form input:focus,
    .telegram-form textarea:focus {
      border-color: #feb900 !important;
      box-shadow: 0 0 0 3px rgba(254,185,0,0.12) !important;
      outline: none !important;
    }
    .btn-warning { transition: transform 0.2s, box-shadow 0.2s; }
    .btn-warning:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(254,185,0,0.35); }
    .btn-warning:active { transform: translateY(0); }
    .btn-sm.rounded-pill { transition: all 0.2s; }
    .btn-sm.rounded-pill:hover { background: #feb900 !important; color: #1a252b !important; border-color: #feb900 !important; }
  </style>

