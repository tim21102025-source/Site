---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const landingSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Встановлення пластикових вікон у Києві",
  "description": "Професійне встановлення металопластикових вікон у Києві та області. Безкоштовний вимір, гарантія 5 років, монтаж за 1 день.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "UWS — Встановлення та Ремонт Вікон",
    "telephone": "+380660575202",
    "address": { "@type": "PostalAddress", "addressLocality": "Київ", "addressCountry": "UA" }
  },
  "areaServed": { "@type": "City", "name": "Київ" },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "UAH",
    "price": "7500",
    "priceSpecification": { "@type": "PriceSpecification", "priceCurrency": "UAH", "minPrice": "5500" }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Скільки коштує встановлення пластикового вікна?", acceptedAnswer: { "@type": "Answer", text: "Ціна залежить від розміру та комплектації. Стандартне вікно — від 5 500 грн, енергозберігаюче — від 7 500 грн, шумозахисне — від 9 500 грн. Точна вартість — після безкоштовного виміру майстром." }},
    { "@type": "Question", "name": "Скільки часу займає встановлення вікон?", acceptedAnswer: { "@type": "Answer", text: "Монтаж одного вікна — 1-2 години. Встановлення вікон у квартирі (3-5 вікон) — за 1 день. Виготовлення вікон — від 3 до 7 робочих днів після виміру." }},
    { "@type": "Question", "name": "Чи надаєте ви гарантію?", acceptedAnswer: { "@type": "Answer", text: "Так, ми надаємо гарантію 5 років на монтаж та комплектуючі. Видаємо офіційний договір та чек. У разі проблем — безкоштовно усуваємо." }},
    { "@type": "Question", "name": "Чи потрібно робити ремонт після встановлення?", acceptedAnswer: { "@type": "Answer", text: "Ні. Наші майстри працюють акуратно, використовують пиловловлювачі. Після монтажу прибирають за собою. Ремонт після нас не потрібен." }},
    { "@type": "Question", "name": "Чи можна встановлювати вікна взимку?", acceptedAnswer: { "@type": "Answer", text: "Так, ми встановлюємо вікна цілий рік. Використовуємо морозостійку монтажну піну та дотримуємося технології при температурах до -15°С." }},
    { "@type": "Question", "name": "Які документи ви надаєте?", acceptedAnswer: { "@type": "Answer", text: "Офіційний договір, рахунок-фактуру, акт виконаних робіт, гарантійний талон на 5 років." }}
  ]
};
---

<BaseLayout
  lang="uk"
  title="Встановлення пластикових вікон у Києві від 5500 грн | UWS"
  description="Встановлення пластикових вікон у Києві: від 5500 грн/вікно. Безкоштовний вимір, монтаж за 1 день, гарантія 5 років. Зателефонуйте зараз!"
  canonicalPath="/landing/vstanovlennya-vikon"
  structuredData={landingSchema}
  robotsNoindex={true}
>

  <Header lang="uk" activePage="home" headerClass="header-solid" />

  <main style="padding-top: 60px;">

    <!-- Hero -->
    <section style="background: linear-gradient(135deg, #1a252b 0%, #2a3d47 100%); padding: 60px 0 50px; position: relative; overflow: hidden;">
      <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: url('/assets/img/hero-carousel/hero-carousel-1.webp') center/cover; opacity: 0.12;"></div>
      <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center gy-4">
          <div class="col-lg-7">
            <div class="d-inline-flex align-items-center gap-2 px-3 py-1 rounded-pill mb-3" style="background: rgba(254,185,0,0.15); border: 1px solid rgba(254,185,0,0.3);">
              <span class="badge bg-warning text-dark rounded-pill" style="font-size: 11px;">АКЦІЯ</span>
              <span style="color: #feb900; font-size: 13px; font-weight: 500;">Знижка 15% на монтаж при замовленні до <span id="hero-deadline">кінця тижня</span></span>
            </div>
            <h1 style="color: #fff; font-size: 40px; font-weight: 800; line-height: 1.12; margin-bottom: 16px;">
              Встановлення пластикових<br>вікон у Києві
            </h1>
            <p style="color: #feb900; font-size: 22px; font-weight: 700; margin-bottom: 8px;">Від 5 500 грн за вікно з монтажем</p>
            <p style="color: rgba(255,255,255,0.7); font-size: 16px; line-height: 1.6; max-width: 500px; margin-bottom: 24px;">
              Безкоштовний вимір · Монтаж за 1 день · Гарантія 5 років · Без передоплати
            </p>
            <div class="d-flex flex-wrap gap-3 mb-4">
              <a href="#calculator" class="btn btn-warning btn-lg px-5 py-3 fw-bold text-dark" style="border-radius: 10px; font-size: 16px;">
                <i class="bi bi-calculator me-2"></i> Розрахувати вартість
              </a>
              <a href="tel:+380660575202" class="btn btn-outline-light btn-lg px-4 py-3 fw-bold" style="border-radius: 10px; font-size: 16px;">
                <i class="bi bi-telephone me-2"></i> Зателефонувати
              </a>
            </div>
            <div class="d-flex align-items-center gap-2" style="color: rgba(255,255,255,0.5); font-size: 13px;">
              <i class="bi bi-clock me-1"></i> Середній час відповіді — 12 хвилин
            </div>
          </div>
          <div class="col-lg-5 d-none d-lg-block">
            <div class="rounded-4 overflow-hidden shadow-lg position-relative" style="border: 2px solid rgba(254,185,0,0.3);">
              <img src="/assets/img/hero-carousel/hero-carousel-2.webp" alt="Встановлення вікон UWS" class="img-fluid w-100" style="height: 320px; object-fit: cover;">
              <div class="position-absolute bottom-0 start-0 end-0 p-3" style="background: linear-gradient(transparent, rgba(0,0,0,0.7));">
                <div class="d-flex align-items-center gap-2">
                  <div class="d-flex" style="color: #feb900;">★★★★★</div>
                  <span style="color: #fff; font-size: 13px;">4.9/5 · 120+ відгуків</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust strip -->
    <section style="background: #f5f6f7; padding: 18px 0; border-bottom: 1px solid #e9ecef;">
      <div class="container">
        <div class="row text-center gy-3">
          <div class="col-6 col-md-3">
            <div class="fw-bold" style="color: #1a252b; font-size: 22px;">8+ років</div>
            <div style="color: #838893; font-size: 12px;">досвіду в Києві</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="fw-bold" style="color: #1a252b; font-size: 22px;">2 500+ вікон</div>
            <div style="color: #838893; font-size: 12px;">встановлено</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="fw-bold" style="color: #1a252b; font-size: 22px;">4.9/5 рейтинг</div>
            <div style="color: #838893; font-size: 12px;">120+ відгуків Google</div>
          </div>
          <div class="col-6 col-md-3">
            <div class="fw-bold" style="color: #1a252b; font-size: 22px;">Гарантія 5 років</div>
            <div style="color: #838893; font-size: 12px;">офіційний договір</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Before / After -->
    <section style="padding: 60px 0;" class="fade-in">
      <div class="container">
        <h2 class="text-center fw-bold mb-2" style="color: #1a252b; font-size: 28px;">Наші роботи: до та після</h2>
        <p class="text-center mb-5" style="color: #838893; font-size: 15px;">Реальні фото наших встановлених вікон у клієнтів</p>
        <div class="row g-3">
          <div class="col-md-4">
            <div class="rounded-4 overflow-hidden position-relative" style="height: 240px;">
              <img src="/assets/img/hero-carousel/hero-carousel-3.webp" alt="До встановлення вікон" class="img-fluid w-100 h-100" style="object-fit: cover;">
              <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-danger text-white px-2 py-1" style="font-size: 11px;">ДО</span>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="rounded-4 overflow-hidden position-relative" style="height: 240px;">
              <img src="/assets/img/hero-carousel/hero-carousel-4.webp" alt="Після встановлення вікон" class="img-fluid w-100 h-100" style="object-fit: cover;">
              <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-success text-white px-2 py-1" style="font-size: 11px;">ПІСЛЯ</span>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="rounded-4 overflow-hidden position-relative" style="height: 240px;">
              <img src="/assets/img/hero-carousel/hero-carousel-5.webp" alt="Результат роботи UWS" class="img-fluid w-100 h-100" style="object-fit: cover;">
              <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-warning text-dark px-2 py-1" style="font-size: 11px;">РЕЗУЛЬТАТ</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section style="padding: 60px 0; background: #f5f6f7;">
      <div class="container">
        <h2 class="text-center fw-bold mb-2" style="color: #1a252b; font-size: 28px;">Як ми працюємо</h2>
        <p class="text-center mb-5" style="color: #838893; font-size: 15px;">Від заявки до нових вікон — 3 прості кроки</p>
        <div class="row gy-4">
          <div class="col-md-4 text-center">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width: 64px; height: 64px; background: rgba(254,185,0,0.12);">
              <span class="fw-bold" style="color: #feb900; font-size: 26px;">1</span>
            </div>
            <h3 class="fw-bold mb-2" style="color: #1a252b; font-size: 17px;">Заявка та вимір</h3>
            <p style="color: #6c757d; font-size: 14px; line-height: 1.6;">Зателефонуйте або залиште заявку. Майстер безкоштовно приїде та зробить точний вимір.</p>
          </div>
          <div class="col-md-4 text-center">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width: 64px; height: 64px; background: rgba(254,185,0,0.12);">
              <span class="fw-bold" style="color: #feb900; font-size: 26px;">2</span>
            </div>
            <h3 class="fw-bold mb-2" style="color: #1a252b; font-size: 17px;">Виготовлення</h3>
            <p style="color: #6c757d; font-size: 14px; line-height: 1.6;">Виготовляємо вікна за 3-7 робочих днів. Ви отримуєте точну дату монтажу.</p>
          </div>
          <div class="col-md-4 text-center">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle" style="width: 64px; height: 64px; background: rgba(254,185,0,0.12);">
              <span class="fw-bold" style="color: #feb900; font-size: 26px;">3</span>
            </div>
            <h3 class="fw-bold mb-2" style="color: #1a252b; font-size: 17px;">Монтаж за 1 день</h3>
            <p style="color: #6c757d; font-size: 14px; line-height: 1.6;">Встановлюємо вікна за 1 день. Прибираємо за собою. Ви приймаєте роботу.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Calculator -->
    <section id="calculator" style="padding: 60px 0; background: linear-gradient(180deg, #f5f6f7 0%, #fff 100%);">
      <div class="container">
        <div class="text-center mb-5">
          <span class="d-inline-block px-3 py-1 rounded-pill mb-3" style="background: rgba(254,185,0,0.12); color: #b8860b; font-size: 12px; font-weight: 600;">ОНЛАЙН-КАЛЬКУЛЯТОР</span>
          <h2 class="fw-bold mb-2" style="color: #1a252b; font-size: 28px;">Розрахуйте вартість за 30 секунд</h2>
          <p style="color: #838893; font-size: 15px;">Оберіть параметри — дізнаєтеся ціну миттєво</p>
        </div>
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <div class="calc-wrapper bg-white rounded-4 p-4 p-md-5 shadow-sm">

              <!-- Step 1: Window type cards -->
              <div class="mb-4">
                <label class="d-block fw-bold mb-3" style="color: #1a252b; font-size: 14px;">
                  <span class="d-inline-flex align-items-center justify-content-center rounded-circle me-2" style="width: 22px; height: 22px; background: #feb900; color: #1a252b; font-size: 12px; font-weight: 700;">1</span>
                  Тип вікна
                </label>
                <div class="row g-3" id="calc-type-cards">
                  <div class="col-md-4">
                    <div class="calc-card d-block rounded-3 p-3 text-center h-100" data-value="5500" style="border: 2px solid #e9ecef; transition: all 0.25s ease; cursor: pointer; position: relative;">
                      <div class="mb-2" style="font-size: 28px;">🏠</div>
                      <div class="fw-bold" style="color: #1a252b; font-size: 14px;">Стандарт</div>
                      <div style="color: #838893; font-size: 12px; line-height: 1.4;">Однокамерний<br>склопакет</div>
                      <div class="fw-bold mt-2" style="color: #feb900; font-size: 18px;">від 5 500</div>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="calc-card d-block rounded-3 p-3 text-center h-100" data-value="7500" style="border: 2px solid #feb900; background: rgba(254,185,0,0.04); transition: all 0.25s ease; cursor: pointer; position: relative;">
                      <div class="position-absolute" style="top: -8px; right: -8px;"><span class="badge bg-warning text-dark px-2 py-1 rounded-pill" style="font-size: 10px;">ХІТ</span></div>
                      <div class="mb-2" style="font-size: 28px;">⚡</div>
                      <div class="fw-bold" style="color: #1a252b; font-size: 14px;">Енергозберігаюче</div>
                      <div style="color: #838893; font-size: 12px; line-height: 1.4;">Двокамерний<br>i-glass</div>
                      <div class="fw-bold mt-2" style="color: #feb900; font-size: 18px;">від 7 500</div>
                    </div>
                  </div>
                  <div class="col-md-4">
                    <div class="calc-card d-block rounded-3 p-3 text-center h-100" data-value="9500" style="border: 2px solid #e9ecef; transition: all 0.25s ease; cursor: pointer; position: relative;">
                      <div class="mb-2" style="font-size: 28px;">🔇</div>
                      <div class="fw-bold" style="color: #1a252b; font-size: 14px;">Шумозахисне</div>
                      <div style="color: #838893; font-size: 12px; line-height: 1.4;">Трикамерний<br>42 дБ</div>
                      <div class="fw-bold mt-2" style="color: #feb900; font-size: 18px;">від 9 500</div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Step 2: Quantity -->
              <div class="mb-4">
                <label class="d-block fw-bold mb-3" style="color: #1a252b; font-size: 14px;">
                  <span class="d-inline-flex align-items-center justify-content-center rounded-circle me-2" style="width: 22px; height: 22px; background: #feb900; color: #1a252b; font-size: 12px; font-weight: 700;">2</span>
                  Кількість вікон
                </label>
                <div class="d-flex align-items-center gap-3">
                  <button type="button" class="calc-qty-btn btn d-flex align-items-center justify-content-center" onclick="calcQty(-1)" style="width: 48px; height: 48px; border-radius: 12px; border: 2px solid #e9ecef; background: #fff; color: #1a252b; font-size: 22px; font-weight: 600; transition: all 0.2s;">−</button>
                  <div class="position-relative">
                    <span id="calc-qty" class="fw-bold" style="color: #1a252b; font-size: 32px; min-width: 50px; text-align: center; display: block;">1</span>
                    <span style="color: #adb5bd; font-size: 11px; display: block; text-align: center;">вікон</span>
                  </div>
                  <button type="button" class="calc-qty-btn btn d-flex align-items-center justify-content-center" onclick="calcQty(1)" style="width: 48px; height: 48px; border-radius: 12px; border: 2px solid #e9ecef; background: #fff; color: #1a252b; font-size: 22px; font-weight: 600; transition: all 0.2s;">+</button>
                  <div class="ms-3 d-flex gap-2">
                    <button type="button" class="btn btn-sm rounded-pill" onclick="setQty(1)" style="border: 1px solid #dee2e6; color: #6c757d; font-size: 12px;">1</button>
                    <button type="button" class="btn btn-sm rounded-pill" onclick="setQty(3)" style="border: 1px solid #dee2e6; color: #6c757d; font-size: 12px;">3</button>
                    <button type="button" class="btn btn-sm rounded-pill" onclick="setQty(5)" style="border: 1px solid #dee2e6; color: #6c757d; font-size: 12px;">5</button>
                  </div>
                </div>
              </div>

              <!-- Step 3: Options -->
              <div class="mb-4">
                <label class="d-block fw-bold mb-3" style="color: #1a252b; font-size: 14px;">
                  <span class="d-inline-flex align-items-center justify-content-center rounded-circle me-2" style="width: 22px; height: 22px; background: #feb900; color: #1a252b; font-size: 12px; font-weight: 700;">3</span>
                  Додаткові послуги
                </label>
                <div class="row g-3">
                  <div class="col-md-6">
                    <div class="calc-option d-flex align-items-center gap-3 p-3 rounded-3" data-option="demontazh" style="border: 2px solid #feb900; background: rgba(254,185,0,0.04); cursor: pointer; transition: all 0.25s ease;">
                      <div class="calc-option-check d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 24px; height: 24px; background: #feb900; border: 2px solid #feb900; transition: all 0.2s;">
                        <i class="bi bi-check-lg" style="color: #1a252b; font-size: 14px;"></i>
                      </div>
                      <div>
                        <div class="fw-bold" style="color: #1a252b; font-size: 14px;">Демонтаж старого вікна</div>
                        <div style="color: #838893; font-size: 12px;">+500 грн за вікно</div>
                      </div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="calc-option d-flex align-items-center gap-3 p-3 rounded-3" data-option="pidvikonnya" style="border: 2px solid #feb900; background: rgba(254,185,0,0.04); cursor: pointer; transition: all 0.25s ease;">
                      <div class="calc-option-check d-flex align-items-center justify-content-center rounded-circle flex-shrink-0" style="width: 24px; height: 24px; background: #feb900; border: 2px solid #feb900; transition: all 0.2s;">
                        <i class="bi bi-check-lg" style="color: #1a252b; font-size: 14px;"></i>
                      </div>
                      <div>
                        <div class="fw-bold" style="color: #1a252b; font-size: 14px;">Підвіконня + відливи</div>
                        <div style="color: #838893; font-size: 12px;">+800 грн за вікно</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Result -->
              <div class="calc-result p-4 rounded-3" style="background: linear-gradient(135deg, #1a252b, #2a3d47); border: 1px solid rgba(254,185,0,0.2);">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                  <div>
                    <div style="color: rgba(255,255,255,0.6); font-size: 13px; margin-bottom: 4px;">Орієнтовна вартість:</div>
                    <div class="d-flex align-items-baseline gap-2">
                      <span class="fw-bold" style="color: #feb900; font-size: 36px; line-height: 1;" id="calc-total">8 300</span>
                      <span style="color: rgba(255,255,255,0.5); font-size: 16px;">грн</span>
                    </div>
                    <div id="calc-breakdown" style="color: rgba(255,255,255,0.4); font-size: 12px; margin-top: 6px;">7 500 × 1 + 500 + 800</div>
                  </div>
                  <div class="text-end">
                    <a href="#form" id="btn-calc-submit" class="btn btn-warning px-4 py-3 fw-bold rounded-3 d-inline-flex align-items-center" style="font-size: 15px;">
                      <i class="bi bi-send me-2"></i> Отримати розрахунок
                    </a>
                    <div style="color: rgba(255,255,255,0.4); font-size: 11px; margin-top: 6px;">*Безкоштовний вимір — ціна не зміниться</div>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Calculator summary strip -->
    <div id="calc-summary" class="d-none" style="position: sticky; top: 60px; z-index: 100; background: rgba(254,185,0,0.97); backdrop-filter: blur(8px); padding: 12px 0; box-shadow: 0 4px 16px rgba(254,185,0,0.3);">
      <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
