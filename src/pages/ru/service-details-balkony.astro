---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactModal from '../../components/ContactModal.astro';
import { getServiceStructuredData } from '../../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Остекление Балконов и Лоджий Киев',
  description: 'Профессиональное остекление, утепление и ремонт балконов и лоджий под ключ в Киеве. Вынос, французское остекление, объединение с комнатой. Гарантия до 5 лет.',
  url: 'https://uws.com.ua/ru/service-details-balkony',
  extra: {
    makesOffer: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Остекление и утепление балконов и лоджий под ключ',
      },
    },
  },
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center"
    style="background-image: url('/assets/img/breadcrumbs-bg.jpg');">
    <div class="container position-relative">
    </div>
  </div>

  <main id="main" class="page-inner">

    <section id="service-details" class="service-details py-5">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Остекление и Ремонт Балконов и Лоджий в Киеве под Ключ</h1>
          <p class="lead text-muted mt-3">UWS превращает ваш балкон в комфортное и функциональное пространство. Тёплое
            остекление, вынос, утепление, объединение с комнатой — всё с гарантией до 5 лет.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="services-list shadow-sm rounded-4 p-4 bg-white">
              <a href="/ru/service-details-install">Установка окон и дверей</a>
              <a href="/ru/service-details-repair">Ремонт окон и дверей</a>
              <a href="/ru/service-details-balkony" class="active">Балконы и лоджии</a>
              <a href="/ru/service-details-moskitki">Москитные сетки</a>
              <a href="/ru/service-details-glass">Замена стеклопакетов</a>
              <a href="/ru/service-details-dovodyachi">Доводчики для дверей</a>
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light shadow-sm">
              <h4 class="fw-bold mb-3">Расширяйте пространство</h4>
              <p class="text-muted">
                Балкон — это не просто место для хранения вещей, а полноценная часть вашего жилья. Мы поможем
                сделать его уютным, тёплым и функциональным.
              </p>
            </div>
          </div>

          <div class="col-lg-8">
            <picture>
              <source srcset="/assets/img/services/balkony.webp" type="image/webp">
              <img src="/assets/img/services/balkony.jpg" alt="Остекление балконов и лоджий под ключ в Киеве — UWS"
              class="img-fluid services-img rounded-4 shadow-sm mb-4" loading="lazy">
            </picture>

            <h2 class="h3 fw-bold mb-4">Остекление, утепление и благоустройство балконов под ключ</h2>
            <p class="lead text-muted mb-5">
              Компания UWS выполняет полный цикл работ по остеклению балконов и лоджий в Киеве. Мы создаём индивидуальные
              решения: от стандартного остекления до превращения балкона в рабочий кабинет или зону отдыха.
            </p>

            <h3 class="h4 fw-bold mb-3">Что мы предлагаем:</h3>
            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Холодное и тёплое остекление:</strong> Выбор оптимального профиля и стеклопакетов в зависимости от
                  ваших потребностей.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Балконы с выносом:</strong> Расширение внутреннего пространства за счёт выноса оконной
                  конструкции за пределы парапета.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Французские балконы:</strong> Остекление от пола до потолка, обеспечивающее максимальное
                  освещение.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Комплексный ремонт:</strong> Усиление парапета, внешняя обшивка, внутреннее утепление и
                  отделка.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Объединение с комнатой:</strong> Демонтаж балконного блока и качественная герметизация для
                  создания единого пространства.</div>
              </li>
            </ul>

            <p class="mt-4 text-muted">
              Наши специалисты обеспечивают надёжную гидроизоляцию и шумоизоляцию. Используем только проверенные материалы,
              устойчивые к перепадам температур и ультрафиолету.
            </p>

            <div class="mt-5 p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
              style="background: linear-gradient(135deg, #364d59 0%, #223139 100%); border: 2px solid #feb900;">

              <div class="position-relative">
                <h3 class="text-white mb-3" style="font-weight: 700;">Хотите рассчитать стоимость вашего балкона?</h3>
                <p class="text-white-50 mb-4 lead">
                  Наш мастер приедет для точных замеров, проконсультирует по выбору материалов и подготовит детальную
                  смету <strong>абсолютно бесплатно</strong>.
                </p>

                <a href="/ru/contact#contact"
                  class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg text-dark d-inline-flex align-items-center">
                  <i class="bi bi-house-door me-2"></i>
                  Вызвать замерщика балконов
                </a>

                <div class="mt-4 text-white-50 small">
                  <i class="bi bi-info-circle me-1 text-warning"></i> Мы официальные партнёры программы єВідновлення —
                  возможна компенсация работ
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>`;
---

<BaseLayout
  lang="ru"
  title={"Остекление Балконов и Лоджий Киев 2026 | Под Ключ — UWS"}
  description={"Остекление балконов и лоджий под ключ в Киеве от UWS. Тёплое и холодное остекление, вынос, утепление, обшивка. Гарантия до 5 лет, бесплатный замер, работа с єВідновлення."}
  canonicalPath={"/ru/service-details-balkony"}
  structuredData={structuredData}
>
  <Header lang="ru" activePage="" headerClass="header-solid" />

  <Fragment set:html={mainHtml} />

  <ContactModal lang="ru" />
  <Footer lang="ru" />
</BaseLayout>
