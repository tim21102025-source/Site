---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactModal from '../../components/ContactModal.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "UWS — Установка и Ремонт Окон Киев",
  "image": "https://uws.com.ua/assets/img/logo.png",
  "telephone": [
    "+380660575202",
    "+380989478772",
    "+380633664769"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "",
    "addressLocality": "Киев",
    "addressRegion": "Киевская область",
    "postalCode": "01001",
    "addressCountry": "UA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 50.4501,
    "longitude": 30.5234
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "09:00",
    "closes": "20:00"
  },
  "description": "Профессиональная установка металлопластиковых окон, дверей и балконов. Ремонт, регулировка, обслуживание в Киеве и области. Гарантия до 5 лет.",
  "url": "https://uws.com.ua/ru/",
  "priceRange": "$$",
  "sameAs": [
    "https://www.facebook.com/uws.kyiv",
    "https://www.instagram.com/uws_kyiv"
  ]
};

const mainHtml = `<!-- Головний блок (Hero) -->
  <section id="hero" class="hero">
    <div class="info d-flex align-items-center">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-6 text-center">
            <!-- Єдиний H1 на сторінці – головний комерційний запит + місто -->
            <h1 data-aos="fade-down">Установка и Ремонт Окон Киев</h1>

            <!-- Підзаголовок H2 – ключові послуги + вигоди -->
            <h2 data-aos="fade-up">Регулировка пластиковых окон · Замена фурнитуры · Гарантия до 5 лет · Бесплатный
              выезд</h2>

            <!-- Короткий опис з ключовими словами -->
            <p data-aos="fade-up">Профессиональная установка металлопластиковых окон, дверей, балконов. Ремонт,
              устранение сквозняков, замена уплотнителя и стеклопакетов в Киеве и области.</p>

            <!-- Кнопка CTA -->
            <a data-aos="fade-up" data-aos-delay="200" href="#get-started" class="btn-get-started">Вызвать мастера</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Карусель фонових зображень – без змін -->
    <div id="hero-carousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
      <div class="carousel-item active" style="background-image: url(/assets/img/hero-carousel/hero-carousel-1.webp)">
      </div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-2.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-3.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-4.webp)"></div>
      <div class="carousel-item" style="background-image: url(/assets/img/hero-carousel/hero-carousel-5.webp)"></div>

      <a class="carousel-control-prev" href="#hero-carousel" role="button" data-bs-slide="prev">
        <span class="carousel-control-prev-icon bi bi-chevron-left" aria-hidden="true"></span>
      </a>
      <a class="carousel-control-next" href="#hero-carousel" role="button" data-bs-slide="next">
        <span class="carousel-control-next-icon bi bi-chevron-right" aria-hidden="true"></span>
      </a>
    </div>
  </section>

  <main id="main">

    <section class="get-started py-5">
      <div class="container">
        <div class="row justify-content-between gy-4">

          <!-- Ліва частина: текст та переваги -->
          <div class="col-lg-6 d-flex align-items-center" data-aos="fade-up">
            <div class="content ps-lg-4">

              <!-- Єдиний H2 у блоці — головний сенс + ключові слова -->
              <h2 class="fw-bold mb-4" style="color: #1a252b;">
                Почему выбирают нас для ремонта и регулировки пластиковых окон в Киеве
              </h2>

              <p class="mb-4 text-secondary" style="font-size: 1rem;">
                Не ждите, пока из окна начнет дуть или сломается ручка. Мы возвращаем тепло, тишину и безопасность в ваш
                дом за один визит, экономя до 40% на отоплении.
              </p>

              <!-- Переваги — без заголовків H6, з сильним текстом -->
              <div class="features-mini mb-4">
                <div class="d-flex align-items-start mb-3">
                  <div class="icon-box bg-warning-light p-2 rounded-3 me-3">
                    <i class="bi bi-patch-check-fill text-warning fs-4"></i>
                  </div>
                  <div>
                    <strong class="fw-bold d-block mb-1">Бесплатный выезд и диагностика</strong>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">
                      При заключении договора мастер проведет полный технический осмотр всех окон бесплатно.
                    </p>
                  </div>
                </div>

                <div class="d-flex align-items-start mb-3">
                  <div class="icon-box bg-warning-light p-2 rounded-3 me-3">
                    <i class="bi bi-camera-fill text-warning fs-4"></i>
                  </div>
                  <div>
                    <strong class="fw-bold d-block mb-1">Мгновенный расчет стоимости</strong>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">
                      Пришлите фото или видео проблемы — наш эксперт оценит стоимость ремонта за 5 минут.
                    </p>
                  </div>
                </div>

                <div class="d-flex align-items-start mb-3">
                  <div class="icon-box bg-warning-light p-2 rounded-3 me-3">
                    <i class="bi bi-shield-lock-fill text-warning fs-4"></i>
                  </div>
                  <div>
                    <strong class="fw-bold d-block mb-1">Гарантия 12 месяцев + официальный договор</strong>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">
                      Используем только оригинальные комплектующие (Германия, Австрия) и предоставляем официальный чек.
                    </p>
                  </div>
                </div>
              </div>

              <!-- Блок месенджерів — H6 замінено на strong -->
              <div class="p-3 rounded-4 bg-white shadow-sm border-start border-warning border-5 mb-4">
                <strong class="fw-bold d-block mb-2" style="font-size: 0.95rem;">Получите консультацию прямо
                  сейчас:</strong>
                <p class="text-muted mb-3" style="font-size: 0.8rem;">Наши мастера онлайн в удобном мессенджере:</p>

                <div class="d-flex flex-wrap gap-2 messenger-buttons-group">
                  <a href="viber://chat?number=%2B380730705280"
                    class="btn text-white px-4 py-2 d-flex align-items-center justify-content-center messenger-btn viber-bg">
                    <i class="bi bi-chat-dots-fill me-2"></i> Viber
                  </a>

                  <a href="https://t.me/+380730705280"
                    class="btn text-white px-4 py-2 d-flex align-items-center justify-content-center messenger-btn telegram-bg">
                    <i class="bi bi-telegram me-2"></i> Telegram
                  </a>

                  <a href="https://wa.me/380730705280"
                    class="btn text-white px-4 py-2 d-flex align-items-center justify-content-center messenger-btn whatsapp-bg">
                    <i class="bi bi-whatsapp me-2"></i> WhatsApp
                  </a>
                </div>
              </div>

            </div>
          </div>

          <!-- Права частина: форма -->
          <div id="get-started" class="col-lg-5" data-aos="fade">
            <form action="" method="post" class="php-email-form telegram-form shadow-lg p-4 p-md-5 rounded-4 bg-white">
              <!-- H3 — підзаголовок форми, логічно після H2 -->
              <h3 class="fs-4 fw-bold mb-2">Быстрая заявка на ремонт окон в Киеве</h3>
              <p class="text-muted small mb-4">Оставьте контакты — мастер перезвонит в течение 15 минут</p>

              <div class="row gy-3">
                <div class="col-md-12 form-group">
                  <input type="text" name="name" class="form-control" placeholder="Ваше имя" required
                    oninvalid="this.setCustomValidity('Пожалуйста, введите ваше имя')"
                    oninput="this.setCustomValidity('')" style="border-radius: 8px; padding: 12px;">
                </div>
                <div class="col-md-12 form-group">
                  <div class="input-group">
                    <span class="input-group-text" style="background: #f8f9fa; border-radius: 8px 0 0 8px;">+38</span>
                    <input type="tel" class="form-control" name="phone" placeholder="066 057 52 02"
                      pattern="^(\\s*\\d){10}\\s*$" required
                      oninvalid="this.setCustomValidity('Введите корректный номер телефона (10 цифр)')"
                      oninput="this.setCustomValidity('')" style="border-radius: 0 8px 8px 0; padding: 12px;">
                  </div>
                </div>
                <div class="col-md-12 form-group">
                  <textarea class="form-control" name="message" rows="3"
                    placeholder="Опишите, что произошло (например: дует из окна, сломалась ручка)" required
                    oninvalid="this.setCustomValidity('Пожалуйста, опишите вашу проблему')"
                    oninput="this.setCustomValidity('')" style="border-radius: 8px; padding: 12px;"></textarea>
                </div>

                <div class="form-group mb-3">
                  <div class="d-flex align-items-center mb-2">
                    <label class="form-label small fw-bold mb-0">Фото или видео проблемы</label>
                    <span class="ms-2 small opacity-50" style="font-size: 0.75rem;">(можно выбрать несколько)</span>
                  </div>

                  <input type="file" id="files" class="d-none" accept="image/*,video/*" multiple>

                  <button type="button"
                    class="btn btn-outline-secondary w-100 py-2 d-flex align-items-center justify-content-center"
                    onclick="document.getElementById('files').click()" style="border-style: dashed;">
                    <i class="bi bi-camera me-2 fs-5"></i>
                    <span>Добавить медиафайлы</span>
                  </button>

                  <div id="file-preview" class="d-flex flex-wrap gap-2 mt-2"></div>
                </div>

                <div class="col-md-12 text-center">
                  <div class="loading">Загрузка</div>
                  <div class="error-message"></div>
                  <div class="sent-message bi bi-check-circle-fill"> Спасибо! Ваша заявка принята. Ожидайте звонка.
                  </div>
                  <input type="text" name="hp_field" style="display:none !important" tabindex="-1" autocomplete="off">
                  <button type="submit" class="w-100 py-3 fw-bold text-dark border-0 shadow-sm btn-animate"
                    style="background: #feb900; border-radius: 8px; transition: 0.3s;">
                    Получить бесплатную консультацию
                  </button>
                </div>
              </div>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- Секція послуг -->
    <section id="services" class="services section-bg">
      <div class="container" data-aos="fade-up">

        <!-- Заголовок секції — H2 з ключовими словами -->
        <div class="section-header">
          <h2 class="fw-bold">Полный спектр услуг по установке и ремонту окон в Киеве</h2>
          <p>От срочного ремонта и регулировки до комплексного остекления балконов — профессиональный подход к каждому
            окну</p>
        </div>

        <div class="row gy-4">

          <!-- Картка 1 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/install.webp" type="image/webp">
                  <img src="/assets/img/services/install.jpg" class="img-fluid w-100"
                  alt="Установка металлопластиковых окон и дверей Киев" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-window-plus"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Установка окон и дверей</h3>
                <p class="text-muted small">Монтаж энергоэффективных систем по стандартам ДСТУ. Гарантия теплоизоляции
                  и долговечности.</p>
                <hr class="my-3 opacity-10">
                <a href="/ru/service-details-install" class="stretched-link text-warning fw-bold text-decoration-none">
                  Подробнее <i class="bi bi-chevron-right small"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Картка 2 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="200">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/repair.webp" type="image/webp">
                  <img src="/assets/img/services/repair.jpg" class="img-fluid w-100"
                  alt="Ремонт и регулировка пластиковых окон Киев" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-tools"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Ремонт окон и дверей</h3>
                <p class="text-muted small">Устранение сквозняков, замена фурнитуры и регулировка. Возвращаем
                  функциональность за один визит.</p>
                <hr class="my-3 opacity-10">
                <a href="/ru/service-details-repair" class="stretched-link text-warning fw-bold text-decoration-none">
                  Подробнее <i class="bi bi-chevron-right small"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Картка 3 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="300">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/balkony.webp" type="image/webp">
                  <img src="/assets/img/services/balkony.jpg" class="img-fluid w-100"
                  alt="Остекление и утепление балконов и лоджий Киев" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-house-door"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Балконы и лоджии</h3>
                <p class="text-muted small">Комплексное остекление, утепление и внутренняя отделка. Превращаем балкон
                  в уютную комнату.</p>
                <hr class="my-3 opacity-10">
                <a href="/ru/service-details-balkony" class="stretched-link text-warning fw-bold text-decoration-none">
                  Подробнее <i class="bi bi-chevron-right small"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Картка 4 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/glass.webp" type="image/webp">
                  <img src="/assets/img/services/glass.jpg" class="img-fluid w-100" alt="Замена стеклопакетов в окнах Киев"
                  style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-aspect-ratio"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Замена стеклопакетов</h3>
                <p class="text-muted small">Замена разбитых или энергосберегающих пакетов. Улучшение шумоизоляции и
                  энергоэффективности.</p>
                <hr class="my-3 opacity-10">
                <a href="/ru/service-details-glass" class="stretched-link text-warning fw-bold text-decoration-none">
                  Подробнее <i class="bi bi-chevron-right small"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Картка 5 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/moskitki.webp" type="image/webp">
                  <img src="/assets/img/services/moskitki.jpg" class="img-fluid w-100"
                  alt="Изготовление и установка москитных сеток Киев" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-shield-check"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Москитные сетки</h3>
                <p class="text-muted small">Все виды сеток: рамочные, рулонные, «Антикошка». Изготовление по вашим
                  размерам за 1-2 дня.</p>
                <hr class="my-3 opacity-10">
                <a href="/ru/service-details-moskitki"
                  class="stretched-link text-warning fw-bold text-decoration-none">
                  Подробнее <i class="bi bi-chevron-right small"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Картка 6 -->
          <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
            <div class="service-card h-100 shadow-sm rounded-4 overflow-hidden bg-white">
              <div class="card-img-top position-relative">
                <picture>
                  <source srcset="/assets/img/services/dovodyachi.webp" type="image/webp">
                  <img src="/assets/img/services/dovodyachi.jpg" class="img-fluid w-100"
                  alt="Установка доводчиков на двери Киев" style="height: 200px; object-fit: cover;" loading="lazy">
                </picture>
                <div class="service-icon-floating"><i class="bi bi-door-closed"></i></div>
              </div>
              <div class="p-4 pt-5 text-center">
                <h3 class="fw-bold">Доводчики для дверей</h3>
                <p class="text-muted small">Профессиональный подбор и монтаж доводчиков на пластиковые и металлические
                  двери. Плавность хода гарантирована.</p>
                <hr class="my-3 opacity-10">
                <a href="/ru/service-details-dovodyachi"
                  class="stretched-link text-warning fw-bold text-decoration-none">
                  Подробнее <i class="bi bi-chevron-right small"></i>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Блок єВідновлення — H4, бо це підтема після H2 -->
        <div
          class="mt-5 p-4 rounded-4 shadow-sm bg-white border-start border-warning border-4 d-flex align-items-center justify-content-between flex-wrap gap-3"
          data-aos="fade-up">
          <div>
            <h4 class="fw-bold mb-1"><i class="bi bi-patch-check text-warning me-2"></i> Работаем по программе
              єВідновлення</h4>
            <p class="mb-0 text-muted">Предоставляем официальные документы и принимаем оплату картой для восстановления
              вашего жилья.</p>
          </div>
          <a href="/ru/vidnovlennya" class="btn btn-warning fw-bold px-4">Узнать больше</a>
        </div>

      </div>
    </section>

    <!-- Секція: 5 причин, чому обирають UWS -->
    <section id="alt-services" class="alt-services">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-around gy-4">

          <!-- Фото зліва — без змін -->
          <div class="col-lg-6 img-bg"
            style="background-image: url(/assets/img/alt-services.jpg); border-radius: 20px; box-shadow: 0 15px 30px rgba(0,0,0,0.1);"
            data-aos="zoom-in" data-aos-delay="100"></div>

          <!-- Права частина: текст -->
          <div class="col-lg-5 d-flex flex-column justify-content-center">

            <!-- H2 — головний заголовок секції з ключовими словами -->
            <h2 class="fw-bold mb-3">5 причин доверить установку и ремонт окон именно UWS</h2>

            <!-- Підзаголовок (p) — пояснення -->
            <p class="text-muted mb-4">Мы сочетаем 10+ лет опыта и современные стандарты сервиса, чтобы ваши окна
              служили десятилетиями:</p>

            <!-- Переваги — без H4, тільки strong + p -->
            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="100">
              <i class="bi bi-award flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">10+ лет
                    опыта</a></strong>
                <p>Знаем все тонкости работы с любыми профильными системами: от классических до элитных.</p>
              </div>
            </div>

            <div class="icon-box d-flex position-relative" data-aos="fade-up" data-aos-delay="200">
              <i class="bi bi-shield-check flex-shrink-0 text-warning" style="font-size: 2rem;"></i>
              <div>
                <strong class="fw-bold d-block mb-1"><a href="#get-started" class="stretched-link">Официальная
                    гарантия</a></strong>
                <p>Предоставляем гарантийный сертификат на выполненные работы и установленные запчасти.</p>
