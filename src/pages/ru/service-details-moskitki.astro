---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactModal from '../../components/ContactModal.astro';
import { getServiceStructuredData } from '../../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Москитные Сетки Киев',
  description: 'Изготовление и установка москитных сеток в Киеве: рамочные, дверные, антикошка, антипыль, рулонные. Индивидуальные размеры, гарантия до 5 лет.',
  url: 'https://uws.com.ua/ru/service-details-moskitki',
  extra: {
    makesOffer: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Изготовление и установка москитных сеток',
      },
    },
  },
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center"
    style="background-image: url('/assets/img/breadcrumbs-bg.jpg');">
    <div class="container position-relative">
    </div>
  </div>

  <main id="main" class="page-inner">

    <section id="service-details" class="service-details py-5">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Москитные Сетки на Окна и Двери Киев</h1>
          <p class="lead text-muted mt-3">UWS изготавливает и устанавливает москитные сетки любого типа: антикошка,
            антипыль, рулонные, дверные. Индивидуальные размеры, гарантия до 5 лет.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="services-list shadow-sm rounded-4 p-4 bg-white">
              <a href="/ru/service-details-install">Установка окон и дверей</a>
              <a href="/ru/service-details-repair">Ремонт окон и дверей</a>
              <a href="/ru/service-details-balkony">Балконы и лоджии</a>
              <a href="/ru/service-details-moskitki" class="active">Москитные сетки</a>
              <a href="/ru/service-details-glass">Замена стеклопакетов</a>
              <a href="/ru/service-details-dovodyachi">Доводчики для дверей</a>
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light shadow-sm">
              <h4 class="fw-bold mb-3">Почему выбирают нас?</h4>
              <p class="text-muted">
                Мы изготавливаем сетки по индивидуальным размерам в течение 1-2 дней. Используем усиленный
                алюминиевый профиль и качественное полотно, которое не выгорает на солнце.
              </p>
            </div>
          </div>

          <div class="col-lg-8">
            <picture>
              <source srcset="/assets/img/services/moskitki.webp" type="image/webp">
              <img src="/assets/img/services/moskitki.jpg"
              alt="Москитные сетки Киев — антикошка, антипыль, рулонные, дверные UWS"
              class="img-fluid services-img rounded-4 shadow-sm mb-4" loading="lazy">
            </picture>

            <h2 class="h3 fw-bold mb-4">Изготовление и установка москитных сеток в Киеве</h2>
            <p class="lead text-muted mb-5">
              Надёжная защита вашего дома от насекомых, тополиного пуха и уличного мусора. Мы предлагаем широкий выбор
              конструкций, подходящих для любых типов окон и дверей.
            </p>

            <h3 class="h4 fw-bold mb-3">Виды сеток, которые мы предлагаем:</h3>
            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Рамочные (внутрипроёмные):</strong> Самый популярный вариант, легко снимаются и моются,
                  не требуют сверления рамы.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Дверные сетки:</strong> На петлях с магнитной защёлкой — идеальное решение для балконных
                  дверей.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Сетка "Антикошка" (Pet Screen):</strong> Особенно прочное полотно, выдерживающее когти
                  домашних животных.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Сетка "Антипыль":</strong> Специальное мелкоячеистое полотно, задерживающее пыльцу и
                  мельчайшие частицы пыли.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Рулонные сетки:</strong> Удобная конструкция, которая сворачивается в короб над окном.</div>
              </li>
            </ul>

            <p class="mt-4 text-muted">
              Наш замерщик приедет к вам с образцами профилей и полотен, поможет выбрать оптимальный вариант и сделает
              точный расчёт на месте.
            </p>

            <div class="mt-5 p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
              style="background: linear-gradient(135deg, #364d59 0%, #223139 100%); border: 2px solid #feb900;">

              <div class="position-relative">
                <h3 class="text-white mb-3" style="font-weight: 700;">Нужен замер и расчёт стоимости сеток?</h3>
                <p class="text-white-50 mb-4 lead">
                  Оставьте заявку — наш мастер свяжется с вами, проконсультирует по видам полотен и согласует время
                  <strong>бесплатного замера</strong>.
                </p>

                <a href="/ru/contact"
                  class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg text-dark d-inline-flex align-items-center">
                  <i class="bi bi-person-check-fill me-2"></i>
                  Бесплатный замер и консультация
                </a>

                <div class="mt-4 text-white-50 small">
                  <i class="bi bi-clock-history me-1 text-warning"></i> Изготовление от 1 до 3 рабочих дней
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>`;
---

<BaseLayout
  lang="ru"
  title={"Москитные Сетки Киев 2026 | Антикошка, Антипыль — UWS"}
  description={"Изготовление и установка москитных сеток в Киеве от UWS: рамочные, дверные, антикошка, антипыль, рулонные. Индивидуальные размеры, быстрое изготовление, гарантия. Бесплатный замер."}
  canonicalPath={"/ru/service-details-moskitki"}
  structuredData={structuredData}
>
  <Header lang="ru" activePage="" headerClass="header-solid" />

  <Fragment set:html={mainHtml} />

  <ContactModal lang="ru" />
  <Footer lang="ru" />
</BaseLayout>
