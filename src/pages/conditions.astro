---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "UWS — Встановлення, Ремонт Вікон Київ",
  "url": "https://uws.com.ua/conditions.html",
  "telephone": [
    "+380660575202",
    "+380989478772",
    "+380633664769"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Київ",
    "addressCountry": "UA"
  },
  "openingHours": "Mo-Su 09:00-20:00",
  "description": "Прозорі умови надання послуг: гарантія до 5 років на ремонт та встановлення металопластикових вікон, дверей, балконів. Учасник програми єВідновлення.",
  "service": {
    "@type": "Service",
    "serviceType": "Ремонт та встановлення вікон",
    "provider": {
      "@type": "Organization",
      "name": "UWS"
    },
    "areaServed": "Київ та Київська область",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Гарантійні зобов'язання",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Гарантія на виконані роботи"
          },
          "priceCurrency": "UAH",
          "price": "0",
          "availability": "https://schema.org/InStock"
        }
      ]
    }
  }
};

const mainHtml = `<div class="page-header-mini d-flex align-items-center" style="background-image: url('/assets/img/breadcrumbs-bg.jpg');">
      <div class="container position-relative"></div>
    </div>



    <!-- Єдиний вступний блок з H1 -->
    <section id="terms-hero" class="py-5">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-center">
          <div class="col-lg-10 text-center">
            <h1 class="display-5 fw-bold mb-4" style="color: var(--color-default);">
              Умови надання послуг та гарантії UWS — Київ 2026
            </h1>
            <p class="lead text-muted mb-0" style="max-width: 760px; margin: 0 auto;">
              Прозорі правила співпраці: безкоштовний виїзд майстра, фіксована ціна в договорі, офіційна гарантія до 5
              років та можливість оплати за програмою <strong>єВідновлення</strong>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Порядок виконання робіт -->
    <section id="process" class="section-bg py-5">
      <div class="container" data-aos="fade-up">
        <div class="section-header text-center">
          <h2 class="fw-bold" style="color: var(--color-default);">Порядок надання послуг</h2>
          <p class="text-muted">Чітка послідовність дій, яка гарантує якість, фіксовану ціну та відсутність сюрпризів
          </p>
        </div>

        <div class="row gy-4">
          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-all"
              style="border-top: 4px solid var(--color-primary);">
              <div class="mb-3">
                <i class="bi bi-telephone-inbound-fill" style="font-size: 3rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">1. Заявка та запис</h3>
              <p class="text-muted">Телефон, сайт, месенджери → погодження зручного часу виїзду (зазвичай 1–2 години або
                наступний день).</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-all"
              style="border-top: 4px solid var(--color-primary);">
              <div class="mb-3">
                <i class="bi bi-rulers" style="font-size: 3rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">2. Безкоштовний виїзд та замір</h3>
              <p class="text-muted">Майстер проводить діагностику, замір, складає точний кошторис (вартість фіксується в
                договорі).</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-all"
              style="border-top: 4px solid var(--color-primary);">
              <div class="mb-3">
                <i class="bi bi-file-earmark-text" style="font-size: 3rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">3. Укладання договору</h3>
              <p class="text-muted">Фіксуємо ціну, терміни, обсяги робіт, гарантійні зобов’язання. Оплата після
                виконання або поетапно.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="400">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-all"
              style="border-top: 4px solid var(--color-primary);">
              <div class="mb-3">
                <i class="bi bi-truck" style="font-size: 3rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">4. Виготовлення / комплектація</h3>
              <p class="text-muted">Стандартні конструкції — 4–7 робочих днів, нестандарт (арки, ламінація) — від 14
                днів.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="500">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-all"
              style="border-top: 4px solid var(--color-primary);">
              <div class="mb-3">
                <i class="bi bi-hammer" style="font-size: 3rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">5. Професійний монтаж</h3>
              <p class="text-muted">Виконання за ДСТУ, з використанням якісних матеріалів. Дотримання технології
                монтажу.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="600">
            <div class="card h-100 border-0 shadow-sm text-center p-4 transition-all"
              style="border-top: 4px solid var(--color-primary);">
              <div class="mb-3">
                <i class="bi bi-shield-check" style="font-size: 3rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">6. Прийом-передача + гарантія</h3>
              <p class="text-muted">Перевірка клієнтом, підписання акту, постановка на гарантійний облік (до 5 років).
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Покращений блок гарантій -->
    <section id="guarantee" class="py-5">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-center">
          <div class="col-lg-10">

            <h2 class="text-center mb-5 fw-bold" style="color: var(--color-default);">
              Гарантійні зобов’язання UWS
            </h2>

            <div class="alert alert-light border border-warning text-center mb-5 shadow-sm" role="alert"
              style="border-width: 3px; background: rgba(254,185,0,0.05);">
              <strong class="text-warning d-block mb-2" style="font-size: 1.25rem;">Важливо</strong>
              <p class="mb-0">
                Згідно з ДСТУ Б В.2.6.-15:2011 мінімальна гарантія на металопластикові конструкції — 3 роки.<br>
                <strong class="text-dark">UWS надає розширену гарантію до 5 років</strong> на всі виконані роботи та
                комплектуючі.
              </p>
            </div>

            <div class="row gy-4">
              <div class="col-md-6">
                <div class="card h-100 shadow border-0 overflow-hidden">
                  <div class="card-header text-white fw-bold text-center py-3"
                    style="background: var(--color-primary);">
                    Гарантія на роботи
                  </div>
                  <div class="card-body">
                    <ul class="list-unstyled mb-0">
                      <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                        <div>
                          <strong class="d-block">Ремонт, регулювання, заміна ущільнювача</strong>
                          <span class="text-muted small">до 5 років</span>
                        </div>
                      </li>
                      <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                        <div>
                          <strong class="d-block">Встановлення вікон / дверей / балконів</strong>
                          <span class="text-muted small">5 років</span>
                        </div>
                      </li>
                      <li class="d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                        <div>
                          <strong class="d-block">Монтажний шов та герметичність</strong>
                          <span class="text-muted small">5 років</span>
                        </div>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="card h-100 shadow border-0 overflow-hidden">
                  <div class="card-header text-white fw-bold text-center py-3"
                    style="background: var(--color-primary);">
                    Гарантія на матеріали
                  </div>
                  <div class="card-body">
                    <ul class="list-unstyled mb-0">
                      <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                        <div>
                          <strong class="d-block">Оригінальна фурнітура MACO, ROTO, GU</strong>
                          <span class="text-muted small">до 5 років</span>
                        </div>
                      </li>
                      <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                        <div>
                          <strong class="d-block">Склопакети</strong>
                          <span class="text-muted small">5 років (відсутність конденсату всередині)</span>
                        </div>
                      </li>
                      <li class="d-flex align-items-start">
                        <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                        <div>
                          <strong class="d-block">Профіль ПВХ</strong>
                          <span class="text-muted small">5 років (відсутність деформації, зміни кольору)</span>
                        </div>
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-5 text-center">
              <p class="text-muted mb-4 fw-medium">
                Гарантія діє за умови дотримання правил експлуатації та своєчасного звернення за сервісом.
              </p>
              <a href="/contact#contact" class="btn btn-warning btn-lg px-5 py-3 fw-bold shadow">
                <i class="bi bi-file-earmark-check me-2"></i>Отримати офіційний розрахунок з гарантією
              </a>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- Важливі нюанси -->
    <section id="important" class="section-bg py-5">
      <div class="container" data-aos="fade-up">
        <h2 class="text-center mb-5 fw-bold" style="color: var(--color-default);">
          Важливі нюанси, які варто знати перед замовленням
        </h2>

        <div class="row gy-4">
          <div class="col-lg-6">
            <div class="icon-box d-flex mb-4 p-3 bg-white shadow-sm rounded-3">
              <i class="bi bi-house-gear fs-3 text-primary flex-shrink-0 me-4"></i>
              <div>
                <h4 class="fw-bold mb-2">Підготовка приміщення</h4>
                <p class="mb-0 text-muted">Звільніть підвіконня, забезпечте вільний доступ 1–1.5 м до прорізів.</p>
              </div>
            </div>

            <div class="icon-box d-flex mb-4 p-3 bg-white shadow-sm rounded-3">
              <i class="bi bi-shield-exclamation fs-3 text-primary flex-shrink-0 me-4"></i>
              <div>
                <h4 class="fw-bold mb-2">Захист інтер’єру</h4>
                <p class="mb-0 text-muted">Рекомендуємо накрити меблі та техніку плівкою — монтаж супроводжується пилом.
                </p>
              </div>
            </div>

            <div class="icon-box d-flex p-3 bg-white shadow-sm rounded-3">
              <i class="bi bi-thermometer-snow fs-3 text-primary flex-shrink-0 me-4"></i>
              <div>
                <h4 class="fw-bold mb-2">Погодні обмеження</h4>
                <p class="mb-0 text-muted">Монтаж не проводиться при температурі нижче -15°C або під час сильного дощу.
                </p>
              </div>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="icon-box d-flex mb-4 p-3 bg-white shadow-sm rounded-3">
              <i class="bi bi-clock-history fs-3 text-primary flex-shrink-0 me-4"></i>
              <div>
                <h4 class="fw-bold mb-2">Терміни виготовлення</h4>
                <p class="mb-0 text-muted">Стандарт — 4–7 робочих днів, арки/ламінація — від 14 днів.</p>
              </div>
            </div>

            <div class="icon-box d-flex mb-4 p-3 bg-white shadow-sm rounded-3">
              <i class="bi bi-lightning-charge fs-3 text-primary flex-shrink-0 me-4"></i>
              <div>
                <h4 class="fw-bold mb-2">Електроенергія</h4>
                <p class="mb-0 text-muted">Потрібна робоча розетка в радіусі 5–10 м від місця робіт.</p>
              </div>
            </div>

            <div class="icon-box d-flex p-3 bg-white shadow-sm rounded-3">
              <i class="bi bi-trash3 fs-3 text-primary flex-shrink-0 me-4"></i>
              <div>
                <h4 class="fw-bold mb-2">Вивіз сміття</h4>
                <p class="mb-0 text-muted">Великогабаритне сміття виноситься на сходовий майданчик (вивозимо за
                  додаткову оплату).</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Фінальний CTA -->
    <section class="py-5">
      <div class="container" data-aos="zoom-in">
        <div class="p-5 rounded-4 text-center shadow-lg"
          style="background: linear-gradient(135deg, #2a3d47 0%, #1a252b 100%); color: white;">
          <h3 class="mb-4 fw-bold">Готові працювати за чіткими та прозорими правилами?</h3>
          <p class="lead mb-4 opacity-90">
            Безкоштовний виїзд майстра, фіксована ціна в договорі, офіційна гарантія до 5 років та можливість оплати за
            програмою <strong>єВідновлення</strong>.
          </p>
          <a href="/contact#contact" class="btn btn-warning btn-lg px-5 py-3 fw-bold shadow">
            <i class="bi bi-clipboard-check me-2"></i> Замовити виїзд та договір
          </a>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"Умови надання послуг, гарантія на ремонт та встановлення вікон Київ | UWS 2026"}
  description={"Офіційні умови співпраці UWS: порядок виклику майстра, терміни монтажу, оплата, гарантія на роботи до 5 років, співпраця з програмою єВідновлення. Київ та область."}
  canonicalPath={"/conditions"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="conditions" />

  <Fragment set:html={mainHtml} />

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
