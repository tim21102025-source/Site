---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import { getServiceStructuredData } from '../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Скління Балконів та Лоджій Київ',
  description: "Професійне скління, утеплення та ремонт балконів і лоджій під ключ у Києві. Винос, французьке скління, об'єднання з кімнатою. Гарантія до 5 років.",
  url: 'https://uws.com.ua/service-details-balkony',
  extra: {
    makesOffer: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: "Скління та утеплення балконів і лоджій під ключ",
      },
    },
  },
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="service-details" class="service-details py-5">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Головний H1 + вступ -->
        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Скління та Ремонт Балконів і Лоджій у Києві під Ключ</h1>
          <p class="lead text-muted mt-3">UWS перетворює ваш балкон на комфортний та функціональний простір. Тепле
            скління, винос, утеплення, об'єднання з кімнатою — все з гарантією до 5 років.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="services-list shadow-sm rounded-4 p-4 bg-white">
              <a href="/service-details-install">Встановлення вікон та дверей</a>
              <a href="/service-details-repair">Ремонт вікон та дверей</a>
              <a href="/service-details-balkony" class="active">Балкони і лоджії</a>
              <a href="/service-details-moskitki">Москітні сітки</a>
              <a href="/service-details-glass">Заміна склопакетів</a>
              <a href="/service-details-dovodyachi">Доводчики для дверей</a>
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light shadow-sm">
              <h4 class="fw-bold mb-3">Розширюйте простір</h4>
              <p class="text-muted">
                Балкон — це не просто місце для зберігання речей, а повноцінна частина вашої оселі. Ми допоможемо
                зробити його затишним, теплим та функціональним.
              </p>
            </div>
          </div>

          <div class="col-lg-8">
            <picture>
              <source srcset="/assets/img/services/balkony.webp" type="image/webp">
              <img src="/assets/img/services/balkony.jpg" alt="Скління балконів та лоджій під ключ у Києві — UWS"
              class="img-fluid services-img rounded-4 shadow-sm mb-4" loading="lazy">
            </picture>

            <h2 class="h3 fw-bold mb-4">Скління, утеплення та благоустрій балконів під ключ</h2>
            <p class="lead text-muted mb-5">
              Компанія UWS виконує повний цикл робіт із засклення балконів та лоджій у Києві. Ми створюємо індивідуальні
              рішення: від стандартного скління до перетворення балкона на робочий кабінет або зону відпочинку.
            </p>

            <h3 class="h4 fw-bold mb-3">Що ми пропонуємо:</h3>
            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Холодне та тепле скління:</strong> Вибір оптимального профілю та склопакетів залежно від
                  ваших потреб.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Балкони з виносом:</strong> Розширення внутрішнього простору за рахунок винесення віконної
                  конструкції за межі парапету.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Французькі балкони:</strong> Скління від підлоги до стелі, що забезпечує максимальне
                  освітлення.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Комплексний ремонт:</strong> Зміцнення парапету, зовнішнє обшивання, внутрішнє утеплення та
                  оздоблення.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Об'єднання з кімнатою:</strong> Демонтаж балконного блоку та якісна герметизація для
                  створення єдиного простору.</div>
              </li>
            </ul>

            <p class="mt-4 text-muted">
              Наші фахівці забезпечують надійну гідроізоляцію та шумоізоляцію. Використовуємо лише перевірені матеріали,
              які стійкі до перепадів температур та ультрафіолету.
            </p>

            <div class="mt-5 p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
              style="background: linear-gradient(135deg, #364d59 0%, #223139 100%); border: 2px solid #feb900;">


              <div class="position-relative">
                <h3 class="text-white mb-3" style="font-weight: 700;">Бажаєте прорахувати вартість вашого балкона?</h3>
                <p class="text-white-50 mb-4 lead">
                  Наш майстер приїде для точних замірів, проконсультує щодо вибору матеріалів та підготує детальний
                  кошторис <strong>абсолютно безкоштовно</strong>.
                </p>

                <a href="/contact"
                  class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg text-dark d-inline-flex align-items-center">
                  <i class="bi bi-house-door me-2"></i>
                  Викликати замірника балконів
                </a>

                <div class="mt-4 text-white-50 small">
                  <i class="bi bi-info-circle me-1 text-warning"></i> Ми офіційні партнери програми єВідновлення —
                  можлива компенсація робіт
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"Скління Балконів та Лоджій Київ 2026 | Під Ключ — UWS"}
  description={"Скління балконів та лоджій під ключ у Києві від UWS. Тепле та холодне скління, винос, утеплення, обшивка. Гарантія до 5 років, безкоштовний замір, робота з єВідновлення."}
  canonicalPath={"/service-details-balkony"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="service-details-balkony" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
