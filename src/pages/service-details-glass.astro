---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import { getServiceStructuredData } from '../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Заміна Склоблоків Київ',
  description: 'Професійна заміна склопакетів у Києві: енергозберігаючі, шумоізоляційні, ударостійкі. Термінова заміна розбитих склопакетів. Гарантія до 5 років.',
  url: 'https://uws.com.ua/service-details-glass',
  extra: {
    makesOffer: {
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: 'Заміна склопакетів у вікнах та дверях',
      },
    },
  },
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <section id="service-details" class="service-details py-5">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Головний H1 + вступ -->
        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Заміна Склоблоків у Вікнах та Дверях Київ</h1>
          <p class="lead text-muted mt-3">UWS пропонує швидку та якісну заміну склопакетів будь-якої складності.
            Енергозберігаючі, шумоізоляційні, ударостійкі пакети з гарантією до 5 років.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="services-list shadow-sm rounded-4 p-4 bg-white">
              <a href="/service-details-install">Встановлення вікон та дверей</a>
              <a href="/service-details-repair">Ремонт вікон та дверей</a>
              <a href="/service-details-balkony">Балкони і лоджії</a>
              <a href="/service-details-moskitki">Москітні сітки</a>
              <a href="/service-details-glass" class="active">Заміна склопакетів</a>
              <a href="/service-details-dovodyachi">Доводчики для дверей</a>
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light shadow-sm">
              <h4 class="fw-bold mb-3">Енергоефективність</h4>
              <p class="text-muted">
                Заміна старого однокамерного склопакета на новий двокамерний з енергозберігаючим напиленням знижує
                втрати тепла до 40% та суттєво покращує шумоізоляцію.
              </p>
            </div>
          </div>

          <div class="col-lg-8">
            <picture>
              <source srcset="/assets/img/services/glass.webp" type="image/webp">
              <img src="/assets/img/services/glass.jpg"
              alt="Заміна склопакетів у вікнах Київ — енергозберігаючі та шумоізоляційні UWS"
              class="img-fluid services-img rounded-4 shadow-sm mb-4" loading="lazy">
            </picture>

            <h2 class="h3 fw-bold mb-4">Професійна заміна склопакетів будь-якої складності</h2>
            <p class="lead text-muted mb-5">
              Склопакет — це найбільша частина вікна, від якої безпосередньо залежить тиша та тепло у вашому домі. Ми
              виконуємо як термінову заміну розбитих склопакетів, так і планову модернізацію вікон для підвищення їхніх
              характеристик.
            </p>

            <h3 class="h4 fw-bold mb-3">Коли необхідна заміна:</h3>
            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Пошкодження скла:</strong> Тріщини, сколи або повне руйнування герметичності.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Конденсат всередині:</strong> Якщо волога накопичується між склами — це ознака
                  розгерметизації.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Покращення ізоляції:</strong> Заміна звичайних пакетів на мультифункціональні або
                  енергозберігаючі (Low-E).</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Шумоізоляція:</strong> Встановлення спеціальних пакетів з різною товщиною скла для захисту
                  від вуличного шуму.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Безпека:</strong> Встановлення ударостійкого скла (Триплекс) або загартованого скла.</div>
              </li>
            </ul>

            <p class="mt-4 text-muted">
              Ми проводимо точний замір з урахуванням товщини пакета та форми штапика. Термін виготовлення нового
              склопакета становить від 2 до 5 робочих днів залежно від складності формули.
            </p>

            <div class="mt-5 p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
              style="background: linear-gradient(135deg, #364d59 0%, #223139 100%); border: 2px solid #feb900;">

              <div class="position-relative">
                <h3 class="text-white mb-3" style="font-weight: 700;">Потрібен замір та розрахунок вартості?</h3>
                <p class="text-white-50 mb-4 lead">
                  Залиште заявку — наш спеціаліст проконсультує вас щодо вибору характеристик скла та відправить майстра
                  для <strong>точного безкоштовного заміру</strong>.
                </p>

                <a href="/contact"
                  class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg text-dark d-inline-flex align-items-center">
                  <i class="bi bi-person-check-fill me-2"></i>
                  Безкоштовний замір та консультація
                </a>

                <div class="mt-4 text-white-50 small">
                  <i class="bi bi-shield-fill-check me-1 text-warning"></i> Використовуємо тільки сертифіковане скло та
                  якісний герметик
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"Заміна Склоблоків Київ 2026 | Енергозберігаючі та Шумоізоляційні — UWS"}
  description={"Професійна заміна склопакетів у Києві від UWS: енергозберігаючі, шумоізоляційні, ударостійкі. Термінова заміна розбитих склопакетів. Безкоштовний замір та консультація майстра."}
  canonicalPath={"/service-details-glass"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="service-details-glass" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
