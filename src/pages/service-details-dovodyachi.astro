---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "UWS — Встановлення та Регулювання Доводчиків Дверей Київ",
  "image": "https://uws.com.ua/assets/img/logo.png",
  "telephone": [
    "+380660575202",
    "+380989478772",
    "+380633664769"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "",
    "addressLocality": "Київ",
    "addressRegion": "Київська область",
    "postalCode": "01001",
    "addressCountry": "UA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 50.4501,
    "longitude": 30.5234
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday",
      "Saturday",
      "Sunday"
    ],
    "opens": "09:00",
    "closes": "20:00"
  },
  "description": "Професійний підбір, монтаж та сезонне регулювання доводчиків дверей у Києві. Бренди GEZE, DORMA, CISA. Гарантія до 5 років.",
  "url": "https://uws.com.ua/service-details-dovodyachi.html",
  "priceRange": "$$",
  "sameAs": [
    "https://www.facebook.com/uws.kyiv",
    "https://www.instagram.com/uws_kyiv"
  ],
  "makesOffer": {
    "@type": "Offer",
    "itemOffered": {
      "@type": "Service",
      "name": "Встановлення та регулювання доводчиків дверей"
    }
  }
};

const mainHtml = `<div class="page-header-mini d-flex align-items-center" style="background-image: url('/assets/img/breadcrumbs-bg.jpg');">
      <div class="container position-relative"></div>
    </div>



    <section id="service-details" class="service-details py-5">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Головний H1 + вступ -->
        <header class="text-center mb-5">
          <h1 class="display-5 fw-bold text-dark">Встановлення та Регулювання Доводчиків Дверей у Києві</h1>
          <p class="lead text-muted mt-3">UWS — професійний монтаж доводчиків GEZE, DORMA, CISA. Термінове регулювання,
            ремонт та заміна. Гарантія до 5 років.</p>
        </header>

        <div class="row gy-4">

          <div class="col-lg-4">
            <div class="services-list shadow-sm rounded-4 p-4 bg-white">
              <a href="/service-details-install">Встановлення вікон та дверей</a>
              <a href="/service-details-repair">Ремонт вікон та дверей</a>
              <a href="/service-details-balkony">Балкони і лоджії</a>
              <a href="/service-details-moskitki">Москітні сітки</a>
              <a href="/service-details-glass">Заміна склопакетів</a>
              <a href="/service-details-dovodyachi" class="active">Доводчики для дверей</a>
            </div>

            <div class="mt-4 p-4 rounded-4 bg-light shadow-sm">
              <h4 class="fw-bold mb-3">Подовжіть життя дверей</h4>
              <p class="text-muted">
                Правильно встановлений доводчик запобігає сильним ударам при закриванні, що захищає петлі, замок та саму
                дверну конструкцію від передчасного зносу.
              </p>
            </div>
          </div>

          <div class="col-lg-8">
            <picture>
              <source srcset="/assets/img/services/dovodyachi.webp" type="image/webp">
              <img src="/assets/img/services/dovodyachi.jpg" alt="Встановлення доводчиків дверей GEZE, DORMA у Києві — UWS"
              class="img-fluid services-img rounded-4 shadow-sm mb-4" loading="lazy">
            </picture>

            <h2 class="h3 fw-bold mb-4">Професійний підбір, встановлення та регулювання доводчиків</h2>
            <p class="lead text-muted mb-5">
              Доводчик — це важливий елемент безпеки та комфорту, особливо в місцях з великою прохідністю. Ми пропонуємо
              встановлення надійних доводчиків від провідних світових виробників на вхідні, міжкімнатні та офісні двері.
            </p>

            <h3 class="h4 fw-bold mb-3">Що ми пропонуємо:</h3>
            <ul class="list-unstyled">
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Підбір за класом потужності:</strong> Обираємо модель залежно від ваги та ширини ваших
                  дверей (від легких пластикових до важких броньованих).</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Професійний монтаж:</strong> Встановлення на будь-які типи поверхонь (метал, ПВХ, дерево,
                  алюміній).</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Сезонне регулювання:</strong> Налаштування швидкості закривання та "дохлопу" при зміні
                  температури повітря.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Ремонт та заміна:</strong> Заміна механізмів, що вийшли з ладу, та усунення протікання
                  оливи.</div>
              </li>
              <li class="d-flex mb-3"><i class="bi bi-check-circle-fill text-warning me-3 fs-5 flex-shrink-0 mt-1"></i>
                <div><strong>Робота з брендами:</strong> Встановлюємо перевірене обладнання GEZE, DORMA, CISA та інші.
                </div>
              </li>
            </ul>

            <p class="mt-4 text-muted">
              Наші майстри знають усі тонкощі налаштування гідравлічних систем доводчиків. Ми гарантуємо плавне та
              безшумне закривання ваших дверей в будь-яких умовах.
            </p>

            <div class="mt-5 p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
              style="background: linear-gradient(135deg, #364d59 0%, #223139 100%); border: 2px solid #feb900;">

              <div class="position-relative">
                <h3 class="text-white mb-3" style="font-weight: 700;">Двері грюкають або не закриваються до кінця?</h3>
                <p class="text-white-50 mb-4 lead">
                  Залиште заявку — наш спеціаліст приїде, підбере потрібний доводчик або налаштує ваш старий механізм
                  <strong>у найкоротші терміни</strong>.
                </p>

                <a href="/contact#contact"
                  class="btn btn-warning btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg text-dark d-inline-flex align-items-center">
                  <i class="bi bi-person-check-fill me-2"></i>
                  Викликати майстра з доводчиків
                </a>

                <div class="mt-4 text-white-50 small">
                  <i class="bi bi-wrench-adjustable me-1 text-warning"></i> Регулювання та налаштування в день звернення
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"Встановлення та Регулювання Доводчиків Дверей Київ 2026 | UWS"}
  description={"Професійний монтаж та регулювання доводчиків дверей у Києві від UWS. Бренди GEZE, DORMA. Терміновий виїзд майстра, гарантія до 5 років. Безкоштовна консультація."}
  canonicalPath={"/service-details-dovodyachi"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="service-details-dovodyachi" />

  <Fragment set:html={mainHtml} />

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
