---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  lang="uk"
  title="404 — Сторінку не знайдено | UWS"
  description="Сторінку не знайдено. Поверніться на головну або зв'яжіться з нами."
  canonicalPath="/"
  robotsNoindex
>
  <Header lang="uk" activePage="home" headerClass="header-solid" />

  <main id="main" class="mt-5">
    <section class="section-bg" style="min-height: 60vh; display: flex; align-items: center;">
      <div class="container text-center">
        <div class="mb-4">
          <i class="bi bi-window-x text-warning" style="font-size: 5rem;"></i>
        </div>
        <h1 class="fw-bold mb-3" style="font-size: 3rem;">404</h1>
        <h2 class="fw-bold mb-3">Сторінку не знайдено</h2>
        <p class="text-muted mb-4" style="max-width: 500px; margin: 0 auto;">
          Можливо, сторінка була переміщена або виправлений посилання. Поверніться на головну або зв'яжіться з нами для консультації.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
          <a href="/" class="btn btn-warning px-4 py-3 fw-bold"><i class="bi bi-house me-2"></i> На головну</a>
          <a href="/contact" class="btn btn-outline-dark px-4 py-3 fw-bold"><i class="bi bi-telephone me-2"></i> Зв'язатися з нами</a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="uk" />
</BaseLayout>
