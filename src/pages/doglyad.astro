---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import { getServiceStructuredData } from '../lib/structuredData';

const structuredData = getServiceStructuredData({
  name: 'UWS — Встановлення та Ремонт Вікон Київ',
  description: 'Професійне встановлення металопластикових вікон, дверей та балконів. Ремонт, регулювання, обслуговування у Києві та області. Гарантія до 5 років.',
  url: 'https://uws.com.ua/doglyad',
});

const mainHtml = `<div class="page-header-mini d-flex align-items-center">
      <div class="container position-relative"></div>
    </div>



    <!-- Єдиний H1 – головний заголовок сторінки -->
    <section id="care-hero" class="py-5 bg-light">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-center">
          <div class="col-lg-10 text-center">
            <div class="mb-5">
              <i class="bi bi-shield-check-fill d-block mx-auto mb-4"
                style="font-size: 5.5rem; color: var(--color-primary); filter: drop-shadow(0 4px 12px rgba(254,185,0,0.3));"></i>
            </div>
            <h1 class="display-5 fw-bold mb-4" style="color: var(--color-default);">
              Догляд за вікнами та дверима: поради та сервісне обслуговування UWS Київ 2026
            </h1>
            <p class="lead text-muted mb-0" style="max-width: 760px; margin: 0 auto;">
              Регулярне обслуговування подовжує термін служби вікон на 10–15 років. Змащування, чищення, регулювання
              зима-літо — все, що потрібно знати.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Чек-лист догляду -->
    <section id="care-rules" class="py-5">
      <div class="container" data-aos="fade-up">
        <div class="section-header pb-4 text-center">
          <h2 class="fw-bold" style="color: var(--color-default);">Базовий чек-лист догляду за вікнами</h2>
          <p class="text-muted">Виконуйте ці прості дії 2 рази на рік — і ваші вікна прослужать довго</p>
        </div>

        <div class="row gy-4 justify-content-center">
          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-droplet-half" style="font-size: 3.8rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Очищення профілю</h3>
              <p class="text-muted">М'яка тканина + миючий засіб без абразивів. Не використовуйте ацетон або розчинники!
              </p>
            </div>
          </div>

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-droplet" style="font-size: 3.8rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Догляд за ущільнювачем</h3>
              <p class="text-muted">Очистіть від бруду, змастіть силіконовою змазкою 2 рази на рік. Це збереже
                еластичність гуми.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-gear-wide-connected" style="font-size: 3.8rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Змащування фурнітури</h3>
              <p class="text-muted">Кілька крапель машинного масла на рухомі частини. Робіть це щорічно — ручка
                працюватиме легко.</p>
            </div>
          </div>

          <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-water" style="font-size: 3.8rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Дренажні отвори</h3>
              <p class="text-muted">Перевіряйте та прочищайте канали внизу рами — це запобігає накопиченню вологи.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Сезонне регулювання – тепер симетрично з попередньою секцією -->
    <section id="seasonal-modes" class="section-bg py-5">
      <div class="container" data-aos="fade-up">
        <div class="section-header pb-4 text-center">
          <h2 class="fw-bold" style="color: var(--color-default);">Сезонне регулювання вікон</h2>
          <p class="text-muted">Вікна мають режими «зима» та «літо» — це не маркетинг, а реальна необхідність</p>
        </div>

        <div class="row gy-4 justify-content-center">
          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-snow" style="font-size: 3.8rem; color: #00d2ff;"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Зимовий режим</h3>
              <p class="text-muted">Посилений притиск стулки до рами — повна герметизація, виключення протягів у морози.
              </p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-sun" style="font-size: 3.8rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Літній режим</h3>
              <p class="text-muted">Послаблений притиск — менший тиск на ущільнювач, продовження його терміну служби.
              </p>
            </div>
          </div>

          <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 border-0 shadow-sm p-4 text-center transition-all hover-lift"
              style="border-top: 5px solid var(--color-primary);">
              <div class="mb-4">
                <i class="bi bi-moisture" style="font-size: 3.8rem; color: var(--color-primary);"></i>
              </div>
              <h3 class="h5 fw-bold mb-3">Боротьба з конденсатом</h3>
              <p class="text-muted">Правильне провітрювання + регулярний догляд за склопакетами — забудьте про «плачучі»
                вікна.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Чому професіонали -->
    <section id="pro-care" class="py-5">
      <div class="container" data-aos="fade-up">
        <div class="row justify-content-center">
          <div class="col-lg-10">
            <div class="text-center mb-5">
              <h2 class="fw-bold" style="color: var(--color-default);">Чому варто довірити догляд професіоналам UWS</h2>
              <p class="text-muted lead">Самостійний догляд — добре, професійний сервіс — значно краще</p>
            </div>

            <div class="row gy-4">
              <div class="col-md-6">
                <div class="icon-box d-flex p-4 bg-white shadow-sm rounded-3 transition-all hover-lift">
                  <i class="bi bi-search fs-3 text-primary flex-shrink-0 me-4"></i>
                  <div>
                    <h3 class="fw-bold mb-2">Повна діагностика</h3>
                    <p class="mb-0 text-muted">Виявимо приховані проблеми, які неможливо побачити самостійно.</p>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="icon-box d-flex p-4 bg-white shadow-sm rounded-3 transition-all hover-lift">
                  <i class="bi bi-droplet-half fs-3 text-primary flex-shrink-0 me-4"></i>
                  <div>
                    <h3 class="fw-bold mb-2">Професійні засоби</h3>
                    <p class="mb-0 text-muted">Спеціальні мастила, які не висихають і не шкодять гумовим елементам.</p>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="icon-box d-flex p-4 bg-white shadow-sm rounded-3 transition-all hover-lift">
                  <i class="bi bi-gear-wide-connected fs-3 text-primary flex-shrink-0 me-4"></i>
                  <div>
                    <h3 class="fw-bold mb-2">Точне регулювання</h3>
                    <p class="mb-0 text-muted">Ідеальний притиск — легкий хід ручки, відсутність протягів.</p>
                  </div>
                </div>
              </div>

              <div class="col-md-6">
                <div class="icon-box d-flex p-4 bg-white shadow-sm rounded-3 transition-all hover-lift">
                  <i class="bi bi-calendar-check fs-3 text-primary flex-shrink-0 me-4"></i>
                  <div>
                    <h3 class="fw-bold mb-2">Підготовка до сезону</h3>
                    <p class="mb-0 text-muted">Переведення на зимовий/літній режим + повний чек-лист.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
    </section>

    <!-- Фінальний CTA — без змін -->
    <section class="contact py-0 pb-5" data-aos="fade-up">
      <div class="container">
        <div class="p-4 p-md-5 rounded-4 shadow-lg text-center position-relative overflow-hidden"
          style="background: linear-gradient(135deg, #2a3d47 0%, #1a252b 100%); border: 1px solid rgba(254, 185, 0, 0.3);">

          <div class="position-relative">
            <div class="mb-4">
              <i class="bi bi-shield-shaded text-warning" style="font-size: 3rem;"></i>
            </div>

            <h2 class="text-white mb-3" style="font-weight: 700; font-size: 2rem;">
              Вікна потребують професійного сервісу?
            </h2>

            <div class="row justify-content-center mb-4">
              <div class="col-lg-8">
                <p class="text-white-50" style="font-size: 1.1rem;">
                  Правильний догляд подовжує життя вікна на 10-15 років. Замовте <span class="text-white">комплексне
                    технічне обслуговування</span>: змащування фурнітури, чищення ущільнювачів та регулювання притиску.
                </p>
              </div>
            </div>

            <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
              <a href="/contact#contact" class="btn btn-warning px-5 py-3 fw-bold shadow">
                <i class="bi bi-calendar-check me-2"></i> Викликати майстра на сервіс
              </a>
              <a href="viber://chat?number=%2B380730705280" class="btn btn-outline-light px-5 py-3 fw-bold">
                <i class="bi bi-chat-dots text-warning me-2"></i> Консультація у Viber
              </a>
            </div>

            <div class="mt-4 d-flex align-items-center justify-content-center flex-wrap gap-4">
              <div class="d-flex align-items-center text-white-50 small"><i
                  class="bi bi-heart-pulse me-2 text-warning"></i> Продовження терміну служби</div>
              <div class="d-flex align-items-center text-white-50 small"><i class="bi bi-snow me-2 text-warning"></i>
                Підготовка до зими</div>
              <div class="d-flex align-items-center text-white-50 small"><i class="bi bi-stars me-2 text-warning"></i>
                Оригінальні мастила</div>
            </div>
          </div>
        </div>
      </div>
    </section>

  `;
---

<BaseLayout
  lang="uk"
  title={"Догляд за вікнами та дверима: поради та сервісне обслуговування | UWS Київ 2026"}
  description={"Як правильно доглядати за металопластиковими вікнами та дверима у 2026 році: змащування фурнітури, чищення ущільнювача, регулювання зима-літо, підготовка до зими. Професійні рекомендації та сервіс UWS Київ."}
  canonicalPath={"/doglyad"}
  structuredData={structuredData}
>
  <Header lang="uk" activePage="doglyad" headerClass="header-solid" />

  <main id="main" class="page-inner">
    <Fragment set:html={mainHtml} />
  </main>

  <ContactModal lang="uk" />
  <Footer lang="uk" />
</BaseLayout>
